APP_NAME=HomePilot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Shanghai

# 生产基础镜像与容器用户
APP_IMAGE=registry.cn-hangzhou.aliyuncs.com/shellphy/homepolit:base
APP_UID=1000
APP_GID=1000

# :80 使用 HTTP；域名启用自动 HTTPS
SERVER_NAME=:80
HTTP_PORT=80
HTTPS_PORT=443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

SANCTUM_EXPIRATION=43200

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=360

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WECHAT_APPID=
WECHAT_SECRET=
WECHAT_SUBSCRIBE_TEMPLATE_ID=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# 生产备份
BACKUP_DIR=./storage/backups
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=7
BACKUP_TIME=03:00

# 小程序 AI 能力默认关闭
AI_CHAT_ENABLED=false
AI_CENSUS_REPORT_ENABLED=false
AI_GLOSSARY_DRAFT_ENABLED=false
