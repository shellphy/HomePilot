/* 全局：色板变量（页面样式一律用 var() 取色，不要再写十六进制）
   + 绿色主题（覆盖 TDesign 品牌色）+ 通用卡片/表单样式 */
page {
  --brand: #06ae56;
  --brand-active: #059a4c;
  --brand-deep: #067a3f;
  --brand-bg: #e4f6ec;
  --text-primary: #1a1a18;
  --text-secondary: #6e6b63;
  --text-muted: #9b978c;
  --bg-page: #f6f6f3;
  --line: #edece7;
  --line-dark: #c9c5ba;
  --warn: #a96a0c;
  --warn-bg: #fbf1de;
  --info: #33639f;
  --info-bg: #e7eef7;
  --done-bg: #efeeea;
  /* 危险语义全端只此一个红：与 TDesign danger 按钮、各处 confirmColor 同值 */
  --danger: #e34d59;
  --danger-bg: #fdecee;

  --td-brand-color: var(--brand);
  --td-brand-color-active: var(--brand-active);
  --td-brand-color-light: var(--brand-bg);

  background: var(--bg-page);
  font-size: 28rpx;
  color: var(--text-primary);
}

.page-body {
  padding: 24rpx 24rpx 48rpx;
}

/* tab 页给自定义 tabBar 留出高度 */
.tabbed {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
/* 整卡可点的统一按压反馈：所有 bind:tap 跳转的卡片都挂这个 hover-class */
.card-hover {
  opacity: 0.85;
}

.kicker {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.muted {
  color: var(--text-secondary);
}

/* 加载中 / 出错提示；出错时整块可点重试 */
.hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 40rpx 0;
  line-height: 1.7;
}
.hint-retry {
  color: var(--brand-deep);
  font-weight: 600;
  margin-top: 8rpx;
}
/* 加载失败态：与「暂无内容」的中性空态在结构与颜色上区分开 */
.load-error-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

/* 状态胶囊 */
.pill {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}
.pill-open { background: var(--brand-bg); color: var(--brand-deep); }
.pill-negotiating { background: var(--warn-bg); color: var(--warn); }
.pill-seeking { background: var(--info-bg); color: var(--info); }
.pill-done { background: var(--done-bg); color: var(--text-muted); }
/* 旁路终态（未成团/已取消）：和「已成团」区分开，但用灰底不抢注意力——收场是常态不是事故 */
.pill-aborted { background: var(--done-bg); color: var(--danger); }

/* 进度条 */
.meter {
  height: 12rpx;
  border-radius: 6rpx;
  background: var(--line);
  overflow: hidden;
}
.meter-fill {
  height: 100%;
  border-radius: 6rpx;
  background: var(--brand);
}

/* ---- 表单通用（登记、发起团购、发布进度、问卷共用）---- */
.form-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 0 8rpx 20rpx;
}

.q-title {
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}
.q-note {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--text-muted);
  margin-left: 12rpx;
}
/* 题目注释：题干下的白话解释（问卷即入门课的容器） */
.q-explain {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin: -8rpx 0 18rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  border: 1rpx solid var(--line);
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 16rpx 26rpx;
  font-size: 26rpx;
}
.chip-on {
  background: var(--brand-bg);
  border-color: var(--brand);
  color: var(--brand-deep);
  font-weight: 600;
}

.fin {
  background: var(--bg-page);
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 27rpx;
  box-sizing: border-box;
  width: 100%;
}
/* textarea 恢复多行样式（.fin 的固定高度只适用于单行 input） */
.farea {
  height: auto;
  min-height: 160rpx;
  line-height: 1.6;
  padding: 18rpx 24rpx;
}

.f-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 20rpx 0 12rpx;
}
.f-label:first-of-type {
  margin-top: 0;
}
.f-required {
  font-size: 20rpx;
  color: var(--danger);
  margin-left: 8rpx;
}

.privacy {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.7;
  padding: 4rpx 8rpx 20rpx;
}

/* ---- 行式表单：标签左、内容右对齐、细分割线（资料编辑、管理端表单共用）---- */
.form-list {
  padding-top: 0;
  padding-bottom: 0;
}
.frow {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 116rpx;
  border-bottom: 1rpx solid var(--line);
}
.frow:last-child {
  border-bottom: none;
}
.frow-hover {
  opacity: 0.55;
}
.frow-label {
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--text-primary);
}
.frow-main {
  flex: 1;
  min-width: 0;
  padding: 20rpx 0;
}
.frow-input {
  flex: 1;
  min-width: 0;
  height: 116rpx;
  text-align: right;
  font-size: 28rpx;
  color: var(--text-primary);
}
.frow-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.frow-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  line-height: 1;
  color: var(--line-dark);
}
/* 行式卡片里的长文本块（textarea 等占整行的控件） */
.fblock {
  padding: 24rpx 0 28rpx;
  border-bottom: 1rpx solid var(--line);
}
.fblock:last-child {
  border-bottom: none;
}

/* ---- 条目列表（团购条件 / 买前必懂）：管理端与用户端表单共用 ---- */
.pair {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.pair-col {
  flex-direction: column;
  align-items: stretch;
}
.pair-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.pair-a {
  flex: 1;
}
.pair-b {
  flex: 2;
}
.pair-del {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: var(--text-muted);
  font-size: 26rpx;
}
/* AI 答疑入口卡：团购/活动详情共用（组件 apply-shared 生效） */
.ask-ai {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ask-ai-title {
  font-size: 27rpx;
  font-weight: 600;
}
.ask-ai-sub {
  margin-top: 4rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
}

/* 「买前必懂」行内的 AI 起草入口：草稿回填后仍由填表人把关 */
.pair-ai {
  flex-shrink: 0;
  padding: 0 12rpx;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 24rpx;
  color: var(--brand-deep);
}
.add-row {
  padding: 16rpx 0 4rpx;
  font-size: 25rpx;
  color: var(--brand-deep);
}

/* ---- 吸底操作条：主操作固定可达；页面内容区加 has-footer 预留高度 ---- */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
}
.has-footer {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}
