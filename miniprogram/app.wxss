/* 全局：绿色主题（覆盖 TDesign 品牌色）+ 通用卡片样式 */
page {
  --td-brand-color: #06ae56;
  --td-brand-color-active: #059a4c;
  --td-brand-color-light: #e4f6ec;
  background: #f6f6f3;
  font-size: 28rpx;
  color: #1a1a18;
}

.page-body {
  padding: 24rpx 24rpx 48rpx;
}

/* tab 页给自定义 tabBar 留出高度 */
.tabbed {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.kicker {
  font-size: 22rpx;
  color: #9b978c;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.muted {
  color: #6e6b63;
}

/* 状态胶囊 */
.pill {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}
.pill-open { background: #e4f6ec; color: #067a3f; }
.pill-negotiating { background: #fbf1de; color: #a96a0c; }
.pill-seeking { background: #e7eef7; color: #33639f; }
.pill-done { background: #efeeea; color: #9b978c; }

/* 进度条 */
.meter {
  height: 12rpx;
  border-radius: 6rpx;
  background: #edece7;
  overflow: hidden;
}
.meter-fill {
  height: 100%;
  border-radius: 6rpx;
  background: #06ae56;
}
