<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="chips filter-chips">
      <view class="chip {{listedFilter === '' ? 'chip-on' : ''}}" data-filter="" bind:tap="pickFilter">全部</view>
      <view class="chip {{listedFilter === 'yes' ? 'chip-on' : ''}}" data-filter="yes" bind:tap="pickFilter">已认证</view>
      <view class="chip {{listedFilter === 'no' ? 'chip-on' : ''}}" data-filter="no" bind:tap="pickFilter">未认证</view>
    </view>

    <!-- 建档：物业/业委会等不自助入驻的身份由管理员在这里建档 -->
    <view class="card">
      <view class="create-head" bind:tap="toggleCreate">
        <text class="create-title">建档相关方</text>
        <text class="create-toggle">{{showCreate ? '收起' : '＋ 新增'}}</text>
      </view>
      <block wx:if="{{showCreate}}">
        <view class="hint create-hint">物业、开发商、业委会不自助入驻，由你建档（建档即认证）；建好后点击档案行绑定成员账号。</view>
        <view class="chips">
          <view
            class="chip {{newType === item.key ? 'chip-on' : ''}}"
            wx:for="{{partyTypes}}"
            wx:key="key"
            data-key="{{item.key}}"
            bind:tap="pickNewType"
          >{{item.label}}</view>
        </view>
        <input class="fin create-input" placeholder="名称，如：天青府物业服务中心" value="{{newName}}" data-field="newName" bind:input="onField" />
        <input class="fin create-input" placeholder="类别（选填），如：物业服务" value="{{newCategory}}" data-field="newCategory" bind:input="onField" />
        <t-button theme="light" size="medium" block loading="{{creating}}" bind:tap="createParty">建档并认证</t-button>
      </block>
    </view>

    <view class="card">
      <block wx:for="{{parties}}" wx:key="id">
        <view class="row">
          <view class="row-main" hover-class="row-hover" data-id="{{item.id}}" bind:tap="expand">
            <view class="row-title">{{item.name || '未填名称'}}</view>
            <view class="row-sub">{{item.type_label}}{{item.category ? ' · ' + item.category : ''}} · {{item.members_count}} 个账号 · {{item.created_at}}</view>
          </view>
          <switch checked="{{item.is_listed}}" data-id="{{item.id}}" data-index="{{index}}" bind:change="toggle" color="#06ae56" />
        </view>

        <!-- 展开：成员账号管理 -->
        <view class="members" wx:if="{{expandedId === item.id}}">
          <view class="member-row" wx:for="{{item.members}}" wx:for-item="member" wx:key="id">
            <view class="row-main">
              <view class="member-name">{{member.nickname || '未设置昵称'}}（ID {{member.id}}）</view>
              <view class="row-sub">{{member.unit_label || '未选楼栋'}}{{member.phone ? ' · ' + member.phone : ' · 未授权手机号'}}</view>
            </view>
            <text
              class="member-unbind"
              data-id="{{item.id}}"
              data-member="{{member.id}}"
              data-name="{{member.nickname}}"
              catch:tap="unbindMember"
            >解绑</text>
          </view>
          <view wx:if="{{!item.members.length}}" class="hint">还没有成员账号。绑定后，该成员就以「{{item.type_label}} · {{item.name}}」身份出现。</view>
          <view class="bind-row">
            <input class="fin bind-input" placeholder="成员 ID 或授权手机号" value="{{bindKey}}" bind:input="onBindInput" />
            <t-button theme="light" size="medium" loading="{{binding}}" data-id="{{item.id}}" bind:tap="bindMember">绑定</t-button>
          </view>
        </view>
      </block>
      <view wx:if="{{!parties.length}}" class="hint">{{listedFilter ? '这个筛选下没有相关方' : '还没有相关方入驻'}}</view>
    </view>
  </page-status>
</view>
