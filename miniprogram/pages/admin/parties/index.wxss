.filter-chips {
  margin-bottom: 24rpx;
}
.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.row-touch {
  opacity: 0.7;
}
