.schema-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.schema-edit {
  flex-shrink: 0;
  color: var(--brand-deep);
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 28rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}

.schema-status {
  margin-top: 24rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  text-align: center;
}
