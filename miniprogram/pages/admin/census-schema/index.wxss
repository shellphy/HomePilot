.schema-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.schema-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}

.schema-edit {
  flex-shrink: 0;
  color: var(--brand-deep);
  font-size: 27rpx;
  font-weight: 600;
  /* 与标题首行对齐，标题换行时也不错位 */
  line-height: 46rpx;
}
.schema-edit-hover {
  opacity: 0.6;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 28rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}

.schema-banner {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 22rpx 26rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid var(--info);
  background: var(--info-bg);
}
.schema-banner-pending {
  border-left-color: var(--info);
  background: var(--info-bg);
}
.schema-banner-done {
  border-left-color: var(--brand);
  background: var(--brand-bg);
}
.schema-banner-title {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.schema-banner-sub {
  font-size: 23rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}
