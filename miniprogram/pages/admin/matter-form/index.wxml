<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 基本信息：短字段统一行式（标签左、值右） -->
    <view class="card form-list">
      <view class="frow">
        <text class="frow-label">标题<text class="f-required">*</text></text>
        <input class="frow-input" value="{{title}}" maxlength="60" data-field="title" bind:input="onInput" />
      </view>

      <!-- 团购专属短字段 -->
      <block wx:if="{{type === 'groupbuy'}}">
        <view class="frow">
          <text class="frow-label">品类<text class="f-required">*</text></text>
          <input class="frow-input" value="{{category}}" maxlength="30" data-field="category" bind:input="onInput" />
        </view>
        <view class="frow">
          <text class="frow-label">阶梯优惠</text>
          <input class="frow-input" value="{{perk}}" maxlength="100" data-field="perk" bind:input="onInput" />
        </view>
        <view class="frow">
          <view class="frow-main">
            <view class="row-title">按户出方案</view>
            <view class="row-sub">中央空调、全屋定制这类非标品：商家逐户沟通需求（如上门量房）单独报价，报名者手机号从「谈判中」起与团长互通。团长发起后自己不能改；中途翻转会改变对报名邻居的隐私承诺，确认弄错了才在这里改</view>
          </view>
          <switch checked="{{needsSurvey}}" data-field="needsSurvey" bind:change="onSwitch" color="#06ae56" />
        </view>
      </block>

      <!-- 目标数（团购/活动/互助/维权）：团购必填 ≥1，与业主端发起口径一致 -->
      <view class="frow" wx:if="{{type !== 'notice' && type !== 'census'}}">
        <text class="frow-label" wx:if="{{type === 'groupbuy'}}">目标人数<text class="f-required">*</text><text class="q-note">达到后去和商家谈价</text></text>
        <text class="frow-label" wx:else>目标数<text class="q-note">0 表示不设目标</text></text>
        <input class="frow-input" type="number" value="{{targetCount}}" data-field="targetCount" bind:input="onInput" />
      </view>

      <!-- 状态流转：单选走 action-sheet，与资料页「身份」同一套交互 -->
      <view class="frow" wx:if="{{stateKeys.length}}" hover-class="frow-hover" bind:tap="chooseState">
        <text class="frow-label">状态</text>
        <text class="frow-value">{{states[state]}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <view class="frow" wx:if="{{type === 'census'}}">
        <view class="frow-main">
          <view class="row-title">征集联系方式</view>
          <view class="row-sub">打开后，参与前需先在个人资料里选好楼栋号并授权手机号</view>
        </view>
        <switch checked="{{collectsContact}}" data-field="collectsContact" bind:change="onSwitch" color="#06ae56" />
      </view>

      <!-- 署名发起：物业/业委会/商家想做的调研，代建后亮明发起方，结果对全小区公开 -->
      <view class="frow" wx:if="{{type === 'census'}}" hover-class="frow-hover" bind:tap="chooseInitiatorParty">
        <view class="frow-main">
          <view class="row-title">署名发起方</view>
          <view class="row-sub">物业/业委会/商家的调研在此署名，业主看得到是谁想了解什么</view>
        </view>
        <text class="frow-value">{{initiatorPartyLabel || '小区官方'}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <view class="frow">
        <view class="frow-main">
          <view class="row-title">公示到小区页</view>
          <view class="row-sub">关闭则对业主隐藏（相当于撤下/待审核）</view>
        </view>
        <switch checked="{{isApproved}}" data-field="isApproved" bind:change="onSwitch" color="#06ae56" />
      </view>
    </view>

    <!-- 长文本：公告正文 / 说明 -->
    <view class="card" wx:if="{{type === 'notice'}}">
      <view class="q-title">公告正文<text class="f-required">*</text></view>
      <textarea class="fin farea" auto-height maxlength="2000" value="{{body}}" data-field="body" bind:input="onInput" />
    </view>
    <view class="card" wx:else>
      <view class="q-title">{{type === 'census' ? '征集说明' : '把事情说清楚'}}</view>
      <textarea class="fin farea" auto-height maxlength="1000" value="{{pitch}}" data-field="pitch" bind:input="onInput" />
    </view>

    <!-- 团购专属条目列表 -->
    <block wx:if="{{type === 'groupbuy'}}">
      <view class="card">
        <view class="q-title">团购条件</view>
        <view class="pair" wx:for="{{terms}}" wx:key="index">
          <input class="fin pair-a" value="{{item.label}}" maxlength="30" data-list="terms" data-index="{{index}}" data-field="label" bind:input="onRowInput" />
          <input class="fin pair-b" value="{{item.value}}" maxlength="100" data-list="terms" data-index="{{index}}" data-field="value" bind:input="onRowInput" />
          <view class="pair-del" data-list="terms" data-index="{{index}}" bind:tap="removeRow">✕</view>
        </view>
        <view class="add-row" data-list="terms" bind:tap="addRow">＋ 添加一条</view>
      </view>
      <view class="card">
        <view class="q-title">买前必懂<text class="q-note">大白话讲清报价单上的词，3~5 条</text></view>
        <view class="pair pair-col" wx:for="{{glossary}}" wx:key="index">
          <view class="pair-head">
            <input class="fin pair-a" value="{{item.term}}" maxlength="30" data-list="glossary" data-index="{{index}}" data-field="term" bind:input="onRowInput" />
            <view class="pair-ai" data-index="{{index}}" bind:tap="aiDraft">AI 起草</view>
            <view class="pair-del" data-list="glossary" data-index="{{index}}" bind:tap="removeRow">✕</view>
          </view>
          <textarea class="fin farea" auto-height value="{{item.explain}}" maxlength="300" data-list="glossary" data-index="{{index}}" data-field="explain" bind:input="onRowInput" />
          <textarea class="fin farea" auto-height value="{{item.judge}}" maxlength="300" data-list="glossary" data-index="{{index}}" data-field="judge" bind:input="onRowInput" />
          <textarea class="fin farea" auto-height value="{{item.caution}}" maxlength="300" data-list="glossary" data-index="{{index}}" data-field="caution" bind:input="onRowInput" />
        </view>
        <view class="add-row" data-list="glossary" bind:tap="addRow">＋ 添加一条</view>
      </view>
    </block>

    <!-- 征集专属：问卷与登记入口 -->
    <view class="card" wx:if="{{type === 'census' && id}}">
      <view class="row" hover-class="row-hover" bind:tap="goSchema">
        <view class="row-main">
          <view class="row-title">问卷题目</view>
          <view class="row-sub">{{moduleCount}} 个模块 · 收到答案后只加题不改题</view>
        </view>
        <text class="row-arrow">›</text>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goRegistrations">
        <view class="row-main">
          <view class="row-title">登记明细</view>
          <view class="row-sub">含楼栋、房号、联系方式，仅管理员可见</view>
        </view>
        <text class="row-arrow">›</text>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goCensusText">
        <view class="row-main">
          <view class="row-title">文本题归纳</view>
          <view class="row-sub">把填空回答归纳成主题后发布到公示面</view>
        </view>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 危险操作与吸底的保存拉开距离，避免误触 -->
    <t-button wx:if="{{id}}" theme="danger" variant="text" block style="width: 100%; margin-top: 40rpx" bind:tap="remove">删除这件事项</t-button>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit">{{id ? '保存' : '发布'}}</t-button>
    </view>
  </page-status>
</view>
