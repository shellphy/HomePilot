<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 基本信息：短字段统一行式（标签左、值右） -->
    <view class="card form-list">
      <view class="frow">
        <text class="frow-label">标题<text class="f-required">*</text></text>
        <input
          class="frow-input"
          value="{{title}}"
          placeholder="一句话说清楚这件事"
          maxlength="60"
          data-field="title"
          bind:input="onInput"
        />
      </view>

      <!-- 团购专属短字段 -->
      <block wx:if="{{type === 'groupbuy'}}">
        <view class="frow">
          <text class="frow-label">品类<text class="f-required">*</text></text>
          <input
            class="frow-input"
            value="{{category}}"
            placeholder="填写商品或服务品类"
            maxlength="30"
            data-field="category"
            bind:input="onInput"
          />
        </view>
        <view class="frow">
          <text class="frow-label">阶梯优惠</text>
          <input
            class="frow-input"
            value="{{perk}}"
            placeholder="例如：满 20 人九折"
            maxlength="100"
            data-field="perk"
            bind:input="onInput"
          />
        </view>
        <!-- 逐人报价：发起时可选；发起后对团长锁定（改联系互通的隐私承诺），管理员可纠错 -->
        <view class="frow" wx:if="{{!id || isAdmin}}">
          <view class="frow-main">
            <view class="row-title">逐人报价</view>
            <view class="row-sub"
              >非标准品每人的方案和价格不同：商家单独和每位报名者沟通、单独报价，手机号从「谈判中」起与团长互通。发起后不可再改</view
            >
          </view>
          <switch checked="{{needsSurvey}}" data-field="needsSurvey" bind:change="onSwitch" color="#06ae56" />
        </view>
        <view class="frow" wx:elif="{{needsSurvey}}">
          <view class="frow-main">
            <view class="row-title">逐人报价</view>
            <view class="row-sub">发起时已选定，不可修改</view>
          </view>
          <text class="frow-value">已开启</text>
        </view>
      </block>

      <!-- 目标数（团购/活动/互助/维权）：团购必填 ≥1，与业主端发起口径一致 -->
      <view class="frow" wx:if="{{type !== 'notice' && type !== 'census'}}">
        <text class="frow-label" wx:if="{{type === 'groupbuy'}}"
          >目标人数<text class="f-required">*</text><text class="q-note">达到后去和商家谈价</text></text
        >
        <text class="frow-label" wx:else>目标数<text class="q-note">0 表示不设目标</text></text>
        <input
          class="frow-input"
          type="number"
          value="{{targetCount}}"
          placeholder="0"
          data-field="targetCount"
          bind:input="onInput"
        />
      </view>

      <block wx:if="{{type === 'groupbuy' || type === 'activity' || type === 'aid'}}">
        <datetime-field
          label="开始时间"
          required="{{type === 'activity' || type === 'aid'}}"
          date="{{startDate}}"
          time="{{startTime}}"
          data-name="start"
          bind:change="onDateTimeChange"
        />
        <datetime-field
          label="报名截止"
          date="{{deadlineDate}}"
          time="{{deadlineTime}}"
          data-name="deadline"
          bind:change="onDateTimeChange"
        />
        <view class="frow">
          <text class="frow-label">地点<text wx:if="{{type === 'activity' || type === 'aid'}}" class="f-required">*</text></text>
          <input
            class="frow-input"
            value="{{location}}"
            placeholder="例如：小区东门活动室"
            maxlength="120"
            data-field="location"
            bind:input="onInput"
          />
        </view>
      </block>

      <!-- 状态流转（管理动作）：单选走 action-sheet，与资料页「身份」同一套交互 -->
      <view class="frow" wx:if="{{isAdmin && stateKeys.length}}" hover-class="frow-hover" bind:tap="chooseState">
        <text class="frow-label">状态</text>
        <text class="frow-value">{{states[state]}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <view class="frow" wx:if="{{type === 'census'}}">
        <view class="frow-main">
          <view class="row-title">征集联系方式</view>
          <view class="row-sub">打开后，参与前需先在个人资料里选好楼栋号并授权手机号</view>
        </view>
        <switch checked="{{collectsContact}}" data-field="collectsContact" bind:change="onSwitch" color="#06ae56" />
      </view>

      <!-- 署名发起（管理动作）：物业/业委会/商家想做的调研，代建后亮明发起方，结果对全小区公开 -->
      <view
        class="frow"
        wx:if="{{isAdmin && type === 'census'}}"
        hover-class="frow-hover"
        bind:tap="chooseInitiatorParty"
      >
        <view class="frow-main">
          <view class="row-title">署名发起方</view>
          <view class="row-sub">物业/业委会/商家的调研在此署名，业主看得到是谁想了解什么</view>
        </view>
        <text class="frow-value">{{initiatorPartyLabel || '小区官方'}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <!-- 已驳回的事项在编辑器里也要一眼可辨（否则和「待审核」一样只是个关闭的开关），理由回显；
           改理由走审核列表，这里打开公示即通过 -->
      <view class="frow" wx:if="{{isAdmin && reviewStatus === 'rejected'}}">
        <view class="frow-main">
          <view class="row-title">当前审核状态</view>
          <view class="row-sub row-sub-reject">已驳回：{{rejectReason}}</view>
        </view>
        <view class="pill pill-reject">已驳回</view>
      </view>

      <view class="frow" wx:if="{{isAdmin && id}}">
        <view class="frow-main">
          <view class="row-title">公示到小区页</view>
          <view class="row-sub">关闭则对业主隐藏（撤下，回到待审核）</view>
        </view>
        <switch checked="{{isApproved}}" data-field="isApproved" bind:change="onSwitch" color="#06ae56" />
      </view>
    </view>

    <!-- 长文本：公告正文 / 说明 -->
    <view class="card" wx:if="{{type === 'notice'}}">
      <view class="q-title">公告正文<text class="f-required">*</text></view>
      <textarea
        class="fin farea"
        auto-height
        maxlength="2000"
        value="{{body}}"
        data-field="body"
        bind:input="onInput"
      />
    </view>
    <view class="card" wx:else>
      <view class="q-title">{{type === 'census' ? '征集说明' : '把事情说清楚'}}</view>
      <textarea
        class="fin farea"
        auto-height
        maxlength="1000"
        value="{{pitch}}"
        data-field="pitch"
        bind:input="onInput"
      />
    </view>

    <!-- 征集专属：发起目的（给参与者看，为什么发这次征集） -->
    <view class="card" wx:if="{{type === 'census'}}">
      <view class="q-title">发起目的<text class="q-note">给参与者看，为什么发这次征集</text></view>
      <textarea
        class="fin farea"
        auto-height
        maxlength="1000"
        value="{{purpose}}"
        data-field="purpose"
        bind:input="onInput"
      />
    </view>

    <!-- 团购专属条目列表 -->
    <block wx:if="{{type === 'groupbuy'}}">
      <view class="card">
        <view class="q-title">团购条件</view>
        <view class="pair" wx:for="{{terms}}" wx:key="index">
          <input
            class="fin pair-a"
            value="{{item.label}}"
            maxlength="30"
            data-list="terms"
            data-index="{{index}}"
            data-field="label"
            bind:input="onRowInput"
          />
          <input
            class="fin pair-b"
            value="{{item.value}}"
            maxlength="100"
            data-list="terms"
            data-index="{{index}}"
            data-field="value"
            bind:input="onRowInput"
          />
          <view class="pair-del" data-list="terms" data-index="{{index}}" bind:tap="removeRow">✕</view>
        </view>
        <view class="add-row" data-list="terms" bind:tap="addRow">＋ 添加一条</view>
      </view>
      <view class="card">
        <view class="q-title">买前必懂<text class="q-note">大白话讲清报价单上的词，先自己写，再让 AI 帮你改顺</text></view>
        <view class="pair pair-col" wx:for="{{glossary}}" wx:key="index">
          <view class="pair-head">
            <input
              class="fin pair-a"
              value="{{item.term}}"
              maxlength="30"
              data-list="glossary"
              data-index="{{index}}"
              data-field="term"
              bind:input="onRowInput"
            />
            <view class="pair-ai" data-index="{{index}}" bind:tap="aiDraft">AI 改写</view>
            <view class="pair-del" data-list="glossary" data-index="{{index}}" bind:tap="removeRow">✕</view>
          </view>
          <textarea
            class="fin farea"
            auto-height
            placeholder="先用大白话写一句这个词是什么、怎么选、避什么坑，再点 AI 改写"
            value="{{item.explain}}"
            maxlength="500"
            data-list="glossary"
            data-index="{{index}}"
            data-field="explain"
            bind:input="onRowInput"
          />
        </view>
        <view class="add-row" data-list="glossary" bind:tap="addRow">＋ 添加一条</view>
      </view>
    </block>

    <!-- 征集专属：问卷与登记入口 -->
    <view class="card" wx:if="{{type === 'census' && id}}">
      <view class="row" hover-class="row-hover" bind:tap="goSchema">
        <view class="row-main">
          <view class="row-title">问卷题目</view>
          <view class="row-sub">{{moduleCount}} 个模块 · 收到答案后只加题不改题</view>
        </view>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 删除（管理动作）：与吸底的保存拉开距离，避免误触 -->
    <t-button
      wx:if="{{isAdmin && id}}"
      theme="danger"
      variant="text"
      block
      style="width: 100%; margin-top: 40rpx"
      bind:tap="remove"
      >删除这件事项</t-button
    >

    <view class="footer-bar">
      <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit"
        >{{type === 'census' && !id ? '保存并配置题目' : (id ? '保存' : (isAdmin ? '发布' : '提交审核'))}}</t-button
      >
    </view>
  </page-status>
</view>
