.pair {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.pair-col {
  flex-direction: column;
  align-items: stretch;
}
.pair-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.pair-a {
  flex: 1;
}
.pair-b {
  flex: 2;
}
.pair-del {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: var(--text-muted);
  font-size: 26rpx;
}
.add-row {
  padding: 16rpx 0 4rpx;
  font-size: 25rpx;
  color: var(--brand-deep);
}
.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}
.del-btn {
  margin-top: 40rpx;
}
