/* .pair / .add-row 条目列表样式已上移 app.wxss（与用户端团购表单共用） */
.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}

/* 已驳回态回显：与审核列表同一套红系胶囊/理由样式 */
.pill-reject {
  flex-shrink: 0;
  background: var(--danger-bg);
  color: var(--danger);
}
.row-sub-reject {
  color: var(--danger);
}

/* 利益关系披露：单选式选项行 */
.rel {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.rel-label {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.rel-opt {
  padding: 20rpx 24rpx;
  margin-top: 12rpx;
  border: 1rpx solid var(--line-dark);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}
.rel-opt-on {
  border-color: var(--brand-deep);
  color: var(--brand-deep);
  background: var(--brand-bg);
}

/* 二手闲置传图的图片网格 */
.shots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.shot-wrap {
  position: relative;
}
.shot {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: var(--line);
}
.shot-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.shot-add {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  border: 2rpx dashed var(--line-dark);
  color: var(--text-muted);
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
