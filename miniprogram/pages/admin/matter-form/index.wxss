/* .pair / .add-row 条目列表样式已上移 app.wxss（与用户端团购表单共用） */
.matter-form-row .frow-label {
  width: 156rpx;
}

.matter-form-input {
  height: 76rpx;
  padding: 0 20rpx;
  background: var(--bg-page);
  border: 1rpx solid var(--line);
  border-radius: 14rpx;
  box-sizing: border-box;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}

/* 已驳回态回显：与审核列表同一套红系胶囊/理由样式 */
.pill-reject {
  flex-shrink: 0;
  background: var(--danger-bg);
  color: var(--danger);
}
.row-sub-reject {
  color: var(--danger);
}
