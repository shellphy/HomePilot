.search-card {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}
.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 24rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}
.answers {
  padding: 8rpx 0 20rpx;
  border-bottom: 1rpx solid var(--line);
}
.aline {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 8rpx 0;
}
.aq {
  font-size: 24rpx;
  color: var(--text-muted);
}
.aa {
  font-size: 24rpx;
  text-align: left;
}
