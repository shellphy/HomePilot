<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card search-card">
      <input class="fin" placeholder="搜昵称 / 楼栋 / 手机号" value="{{keyword}}" bind:input="onSearch" />
    </view>
    <view class="card">
      <!-- 总量概览：团长最常问的「到底登记了多少人」放在最显眼处 -->
      <view class="kicker" wx:if="{{all.length}}">{{keyword ? '命中 ' + registrations.length + ' 位 · ' : ''}}共 {{all.length}} 位登记 · {{phoneCount}} 位留了手机</view>
      <block wx:for="{{registrations}}" wx:key="id">
        <view class="row" hover-class="row-hover" data-id="{{item.id}}" bind:tap="toggle">
          <view class="row-main">
            <view class="row-title">{{item.unit_label || '未填楼栋'}}{{item.room_label ? ' ' + item.room_label : ''}} · {{item.nickname}}</view>
            <view class="row-sub">手机 {{item.phone || '未授权'}} · {{item.created_at}}</view>
          </view>
          <text class="row-arrow">{{openId === item.id ? '︿' : '﹀'}}</text>
        </view>
        <view class="answers" wx:if="{{openId === item.id}}">
          <view class="aline" wx:for="{{item.answers}}" wx:for-item="answer" wx:key="question">
            <text class="aq">{{answer.question}}</text>
            <text class="aa">{{answer.answer}}</text>
          </view>
          <view wx:if="{{!item.answers.length}}" class="hint">没有答案</view>
        </view>
      </block>
      <view wx:if="{{!registrations.length}}" class="hint">{{keyword ? '没有匹配的登记' : '还没有人登记'}}</view>
    </view>
  </page-status>
</view>
