.search-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.search-line .fin {
  flex: 1;
}
.hit {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--brand);
  font-weight: 600;
}

.answer {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
  color: var(--text-primary);
  word-break: break-all;
}
.answer:last-child {
  border-bottom: none;
}

.theme-edit {
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx dashed var(--line);
}
.theme-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.theme-title-input {
  flex: 1;
}
.theme-count-input {
  width: 140rpx;
  flex-shrink: 0;
}
.theme-remove {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: var(--text-muted);
  font-size: 28rpx;
}

.add-theme {
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
}
