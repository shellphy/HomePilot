<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card" wx:if="{{!questions.length}}">
      <view class="hint">这期征集没有填空题</view>
    </view>

    <block wx:if="{{questions.length}}">
      <!-- 多道填空题时切题 -->
      <view class="chips" wx:if="{{questions.length > 1}}">
        <view
          class="chip {{qi === index ? 'chip-on' : ''}}"
          wx:for="{{questions}}"
          wx:key="key"
          data-qi="{{index}}"
          bind:tap="pickQuestion"
        >{{item.text}}</view>
      </view>

      <!-- 明细浏览：匿名原文 + 搜索即时计数（辅助数条数） -->
      <view class="card">
        <view class="kicker">{{questions[qi].text}}（{{questions[qi].answers.length}} 条）</view>
        <view class="search-line">
          <input class="fin" placeholder="搜关键词数条数，如：渗水" value="{{keyword}}" bind:input="onSearch" />
          <view class="hit" wx:if="{{keyword}}">命中 {{hitCount}} 条</view>
        </view>
        <view class="answer" wx:for="{{shownAnswers}}" wx:key="index">{{item}}</view>
        <view class="hint" wx:if="{{!shownAnswers.length}}">{{keyword ? '没有包含该词的回答' : '还没有人回答这道题'}}</view>
      </view>

      <!-- 归纳编辑：主题 + 条数 + 概括 -->
      <view class="card">
        <view class="kicker">归纳（{{published ? '已发布' : '未发布'}}）</view>
        <view class="theme-edit" wx:for="{{themes}}" wx:key="index">
          <view class="theme-line">
            <input
              class="fin theme-title-input"
              placeholder="主题，如：渗水漏水"
              value="{{item.title}}"
              data-index="{{index}}"
              data-field="title"
              bind:input="onThemeInput"
            />
            <input
              class="fin theme-count-input"
              type="number"
              placeholder="条数"
              value="{{item.count}}"
              data-index="{{index}}"
              data-field="count"
              bind:input="onThemeInput"
            />
            <view class="theme-remove" data-index="{{index}}" bind:tap="removeTheme">✕</view>
          </view>
          <input
            class="fin"
            placeholder="一句话概括（选填），如：飘窗、卫生间为主"
            value="{{item.note}}"
            data-index="{{index}}"
            data-field="note"
            bind:input="onThemeInput"
          />
        </view>
        <view class="add-theme" bind:tap="addTheme">＋ 添加主题</view>
        <view class="hint">发布后，主题会替代原文出现在本期公示面；原文任何时候都不公开</view>
      </view>

      <t-button
        theme="primary"
        block
        size="large"
        loading="{{submitting}}"
        style="width: 100%; margin-bottom: 12rpx"
        bind:tap="publish"
      >发布到公示面</t-button>
      <t-button theme="default" variant="outline" block size="large" style="width: 100%" bind:tap="saveDraft">仅保存草稿</t-button>
    </block>
  </page-status>
</view>
