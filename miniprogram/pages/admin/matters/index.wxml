<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <t-button theme="primary" block bind:tap="goCreate">发布新事务</t-button>

    <view class="chips filter-chips">
      <view class="chip {{typeFilter === '' ? 'chip-on' : ''}}" data-type="" bind:tap="pickType">全部类型</view>
      <view
        class="chip {{typeFilter === item.key ? 'chip-on' : ''}}"
        wx:for="{{matterTypes}}"
        wx:key="key"
        data-type="{{item.key}}"
        bind:tap="pickType"
      >{{item.label}}</view>
    </view>
    <view class="chips filter-chips">
      <view class="chip {{stateFilter === '' ? 'chip-on' : ''}}" data-state="" bind:tap="pickState">全部状态</view>
      <view class="chip {{stateFilter === 'pending' ? 'chip-on' : ''}}" data-state="pending" bind:tap="pickState">待审核</view>
      <view class="chip {{stateFilter === 'approved' ? 'chip-on' : ''}}" data-state="approved" bind:tap="pickState">已公示</view>
    </view>

    <view class="card list-card">
      <view class="row" wx:for="{{matters}}" wx:key="id" data-id="{{item.id}}" bind:tap="goEdit">
        <view class="row-main">
          <view class="row-title">{{item.title}}</view>
          <view class="row-sub">{{item.type_label}} · {{item.state_label}} · {{item.initiator}}</view>
          <view class="row-sub">{{item.join_count ? item.join_count + ' 人参与' : ''}}{{item.join_count && item.register_count ? ' · ' : ''}}{{item.register_count ? item.register_count + ' 户登记' : ''}}</view>
        </view>
        <view
          wx:if="{{!item.is_approved}}"
          class="approve-btn"
          hover-class="approve-btn-hover"
          data-id="{{item.id}}"
          catch:tap="approve"
        >通过</view>
        <view wx:else class="pill pill-open">已公示</view>
      </view>

      <view wx:if="{{!matters.length}}" class="hint">{{stateFilter === 'pending' ? '没有待审核的事务' : '这个筛选下没有事务'}}</view>
    </view>
  </page-status>
</view>
