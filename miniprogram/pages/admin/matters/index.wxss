.list-card {
  margin-top: 8rpx;
}
.filter-chips {
  margin-top: 24rpx;
}
.filter-chips + .filter-chips {
  margin-top: 12rpx;
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.approve-btn {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: var(--brand);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}
.approve-btn-hover {
  opacity: 0.8;
}
