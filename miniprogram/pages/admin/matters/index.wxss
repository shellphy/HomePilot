.list-card {
  margin-top: 24rpx;
}
.filter-chips + .filter-chips {
  margin-top: 12rpx;
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.55;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
/* 审核是把关动作，通过/驳回视觉权重接近（都描边），不诱导一键放行；
   实心绿留给「发布新事项」这类真正的推荐主动作 */
.approve-btn {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--brand-deep);
  border: 1rpx solid var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}
.approve-btn-hover {
  opacity: 0.8;
}

.approve-btn-reject {
  margin-right: 12rpx;
  background: #ffffff;
  color: var(--danger);
  border: 1rpx solid #e5e2da;
}
