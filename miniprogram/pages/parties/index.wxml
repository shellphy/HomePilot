<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="hint intro">名录里的商家身份都经过管理员核验；核验只确认是真实存在的商家，不代表平台为其服务质量担保。评价全部来自参过团的业主。</view>

    <view class="card party" hover-class="card-hover" wx:for="{{parties}}" wx:key="id" data-id="{{item.id}}" bind:tap="goDetail">
      <view class="party-row">
        <view class="party-name">{{item.name}}</view>
        <view class="party-badge">✓ 身份已核验</view>
      </view>
      <view class="party-sub" wx:if="{{item.intro}}">{{item.intro}}</view>
      <view class="party-sub" wx:if="{{item.category}}">主营：{{item.category}}</view>
      <view class="party-sub party-phone" wx:if="{{item.phone}}" data-phone="{{item.phone}}" catch:tap="callParty">电话：{{item.phone}}（点击拨打 / 复制）</view>
      <view class="party-note">{{item.note}} · 点击看详情</view>
    </view>

    <view wx:if="{{!parties.length}}" class="hint">还没有商家通过认证</view>

    <view class="register-cta">
      <t-button theme="light" size="medium" block bind:tap="goRegister">成为入驻相关方</t-button>
      <view class="register-note">商家 / 物业 / 业委会都可以入驻，认证后对全小区公示</view>
    </view>
  </page-status>
</view>
