.intro {
  padding: 20rpx 8rpx 4rpx;
}

.party {
  padding: 28rpx;
}

.party-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.party-name {
  font-size: 30rpx;
  font-weight: 600;
}

/* 与商家详情页的核验徽章同款：名录/详情同一枚标识长一个样 */
.party-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--brand-deep);
  background: var(--brand-bg);
  border-radius: 8rpx;
  padding: 6rpx 14rpx;
}

.party-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b675e;
}

.party-phone {
  color: var(--brand-deep);
}

.party-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9b978c;
}

.register-cta {
  margin-top: 32rpx;
}
.register-note {
  margin-top: 12rpx;
  text-align: center;
  font-size: 23rpx;
  color: var(--text-muted);
}
