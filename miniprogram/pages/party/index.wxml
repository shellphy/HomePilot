<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <block wx:if="{{party}}">
      <view class="card">
        <view class="party-row">
          <view class="party-name">{{party.name}}</view>
          <view class="party-badge {{party.is_listed ? '' : 'party-badge-pending'}}">{{party.is_listed ? '✓ 身份已核验 · ' + party.label : party.label + ' · ' + party.review_status_label}}</view>
        </view>
        <view class="party-intro" wx:if="{{party.intro}}">{{party.intro}}</view>
        <view class="party-sub" wx:if="{{party.category}}">主营：{{party.category}}</view>
        <view class="party-sub party-phone" wx:if="{{party.phone}}" bind:tap="callParty">电话：{{party.phone}}（点击拨打 / 复制）</view>
        <view class="party-sub" wx:if="{{note}}">{{note}}</view>
        <view class="party-verify" wx:if="{{party.is_listed}}">身份由管理员核验{{party.reviewed_on ? '（' + party.reviewed_on + '）' : ''}}，不代表平台为其服务质量担保。</view>
      </view>

      <view class="card" wx:if="{{party.description}}">
        <view class="kicker">详细介绍</view>
        <view class="party-desc">{{party.description}}</view>
      </view>

      <view class="card" wx:if="{{party.images.length}}">
        <view class="kicker">照片</view>
        <view class="gallery">
          <image
            wx:for="{{party.images}}"
            wx:key="*this"
            class="gallery-shot"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bind:tap="previewImage"
          />
        </view>
      </view>

      <view class="hint hint-reject" wx:if="{{party.review_status === 'rejected'}}">未通过：{{party.reject_reason}}。可在「我的 · 个人资料」改资料后重新提交。</view>
      <view class="hint" wx:elif="{{!party.is_listed}}">这份档案还没通过核验，暂时不对小区公开。</view>
    </block>
  </page-status>
</view>
