.q-title {
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}
.q-note {
  font-size: 22rpx;
  font-weight: 400;
  color: #9b978c;
  margin-left: 12rpx;
}
.q-tip {
  font-size: 22rpx;
  color: #9b978c;
  margin-top: 14rpx;
  line-height: 1.6;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  border: 1rpx solid #edece7;
  background: #f6f6f3;
  border-radius: 16rpx;
  padding: 16rpx 26rpx;
  font-size: 26rpx;
}
.chip-on {
  background: #e4f6ec;
  border-color: #06ae56;
  color: #067a3f;
  font-weight: 600;
}

.fin {
  background: #f6f6f3;
  border: 1rpx solid #edece7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 27rpx;
  box-sizing: border-box;
  width: 100%;
}
.fin-top {
  margin-top: 16rpx;
}
/* textarea 恢复多行样式（.fin 的固定高度只适用于单行 input） */
.farea,
.farea-sm {
  height: auto;
  line-height: 1.6;
  padding: 18rpx 24rpx;
}
.farea {
  min-height: 160rpx;
}
.farea-sm {
  min-height: 100rpx;
  margin-top: 12rpx;
}
.gl-term {
  min-width: 0;
}

.row-item {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 14rpx;
}
.row-label {
  flex: 2;
  min-width: 0;
}
.row-value {
  flex: 5;
  min-width: 0;
}
.row-del {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f6f6f3;
  color: #9b978c;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.row-add {
  text-align: center;
  font-size: 25rpx;
  color: #067a3f;
  padding: 12rpx 0 4rpx;
}

.gl-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #edece7;
}
.gl-head {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.gl-term {
  flex: 1;
}

.privacy {
  font-size: 22rpx;
  color: #9b978c;
  line-height: 1.7;
  padding: 4rpx 8rpx 20rpx;
  text-align: center;
}
