.q-tip {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
  line-height: 1.6;
}

.fin-top {
  margin-top: 16rpx;
}
.farea-sm {
  height: auto;
  min-height: 100rpx;
  line-height: 1.6;
  padding: 18rpx 24rpx;
  margin-top: 12rpx;
}

.row-item {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 14rpx;
}
.row-label {
  flex: 2;
  min-width: 0;
}
.row-value {
  flex: 5;
  min-width: 0;
}
.row-del {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--bg-page);
  color: var(--text-muted);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.row-add {
  text-align: center;
  font-size: 25rpx;
  color: var(--brand-deep);
  padding: 12rpx 0 4rpx;
}

.gl-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--line);
}
.gl-head {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.gl-term {
  flex: 1;
  min-width: 0;
}

.privacy {
  text-align: center;
}
