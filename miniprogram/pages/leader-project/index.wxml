<view class="page-body">
  <view class="card">
    <view class="q-title">品类</view>
    <view class="chips">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="chip {{category === item ? 'chip-on' : ''}}"
        data-value="{{item}}"
        bindtap="pickCategory"
      >{{item}}</view>
    </view>
    <input class="fin fin-top" placeholder="或自定义品类，如 智能家居" value="{{customCategory}}" data-field="customCategory" bindinput="onInput" />
  </view>

  <view class="card">
    <view class="q-title">标题</view>
    <input class="fin" placeholder="如：门窗团购（断桥铝）" value="{{title}}" data-field="title" bindinput="onInput" />
  </view>

  <view class="card">
    <view class="q-title">状态</view>
    <view class="chips">
      <view
        wx:for="{{statuses}}"
        wx:key="value"
        class="chip {{status === item.value ? 'chip-on' : ''}}"
        data-value="{{item.value}}"
        bindtap="pickStatus"
      >{{item.label}}</view>
    </view>
    <view class="q-tip">还没谈价 → 选「意向征集」先探人数；条件谈好了 → 选「接龙中」正式报名</view>
  </view>

  <view class="card">
    <view class="q-title">目标户数</view>
    <input class="fin" type="number" placeholder="达到后你会去和商家谈价" value="{{targetHouseholds}}" data-field="targetHouseholds" bindinput="onInput" />
  </view>

  <view class="card">
    <view class="q-title">团长的话<text class="q-note">写给邻居看，透明是信任的来源</text></view>
    <textarea class="fin farea" auto-height placeholder="如：我自己家就用这家，条件对每户一样" value="{{pitch}}" data-field="pitch" bindinput="onInput" maxlength="1000" />
  </view>

  <view class="card">
    <view class="q-title">团购条件<text class="q-note">谈成后再填也可以</text></view>
    <view class="row-item" wx:for="{{terms}}" wx:key="index">
      <input class="fin row-label" placeholder="名目" value="{{item.label}}" data-list="terms" data-index="{{index}}" data-key="label" bindinput="onRowInput" />
      <input class="fin row-value" placeholder="如 618 元/㎡" value="{{item.value}}" data-list="terms" data-index="{{index}}" data-key="value" bindinput="onRowInput" />
      <view class="row-del" data-index="{{index}}" bindtap="removeTerm">✕</view>
    </view>
    <view class="row-add" bindtap="addTerm">+ 添加一条条件</view>
  </view>

  <view class="card">
    <view class="q-title">阶梯优惠</view>
    <input class="fin" placeholder="如：满 20 户赠全屋水电升级" value="{{perk}}" data-field="perk" bindinput="onInput" />
  </view>

  <view class="card">
    <view class="q-title">买前必懂<text class="q-note">3~5 条，术语 → 大白话</text></view>
    <view class="gl-item" wx:for="{{glossary}}" wx:key="index">
      <view class="gl-head">
        <input class="fin gl-term" placeholder="术语，如 断桥铝" value="{{item.term}}" data-list="glossary" data-index="{{index}}" data-key="term" bindinput="onRowInput" />
        <view class="row-del" data-index="{{index}}" bindtap="removeGlossary">✕</view>
      </view>
      <textarea class="fin farea-sm" auto-height placeholder="大白话解释这个术语" value="{{item.explain}}" data-list="glossary" data-index="{{index}}" data-key="explain" bindinput="onRowInput" maxlength="300" />
    </view>
    <view class="row-add" bindtap="addGlossary">+ 添加一条</view>
  </view>

  <view class="privacy">发起即成为本团团长，负责对接商家和更新进度。小程序不代收任何款项，签约与付款由业主直接对商家。</view>
  <t-button theme="primary" block size="large" loading="{{submitting}}" bind:tap="submit">{{id ? '保存修改' : '提交审核'}}</t-button>
</view>
