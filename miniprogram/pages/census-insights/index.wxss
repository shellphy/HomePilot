.hero-num {
  font-size: 56rpx;
  font-weight: 700;
}
.hero-sub {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-muted);
}
.hero-sign {
  font-size: 23rpx;
  color: var(--info);
  margin-top: 6rpx;
}
.hero-cap {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 6rpx 0 20rpx;
}
/* 配套征集的回链：跳回它服务的团购 */
.related-link {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--line);
  font-size: 24rpx;
  color: var(--brand-deep);
}

.bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
  font-size: 24rpx;
}
.bar:last-child {
  margin-bottom: 0;
}
.bar-label {
  width: 190rpx;
  text-align: left;
  color: var(--text-secondary);
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 24rpx;
  border-radius: 8rpx;
  background: var(--bg-page);
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: var(--brand);
  border-radius: 0 8rpx 8rpx 0;
}
.bar-value {
  width: 60rpx;
  font-weight: 600;
}

.qa {
  margin-bottom: 24rpx;
}
.qa:last-child {
  margin-bottom: 0;
}
.qa-text {
  font-size: 25rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.theme {
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  background: var(--bg-page);
  margin-bottom: 12rpx;
}
.theme-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 25rpx;
}
.theme-title {
  font-weight: 600;
}
.theme-count {
  color: var(--brand);
  font-weight: 600;
  font-size: 24rpx;
}
.theme-note {
  font-size: 23rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.theme-foot {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* 个人登记入口固定在统计内容之前 */
.my-registration-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--brand-bg);
  border: 1rpx solid var(--brand);
}
.my-registration-title {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--brand-deep);
}
.my-registration-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.stats-section {
  padding-top: 0;
  padding-bottom: 0;
}
.stats-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 108rpx;
}
.stats-section-title {
  font-size: 28rpx;
  font-weight: 600;
}
.stats-section-count {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}
.stats-section-arrow {
  font-size: 38rpx;
  line-height: 1;
  color: var(--text-muted);
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}
.stats-section-arrow-open {
  transform: rotate(-90deg);
}
.stats-section-content {
  padding: 22rpx 0 4rpx;
  border-top: 1rpx solid var(--line);
}

.admin-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.admin-entry-title {
  font-size: 27rpx;
  font-weight: 600;
}
.admin-entry-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}
