.hero-num {
  font-size: 56rpx;
  font-weight: 700;
}
.hero-sub {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-muted);
}
.hero-cap {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 6rpx 0 20rpx;
}

.bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
  font-size: 24rpx;
}
.bar:last-child {
  margin-bottom: 0;
}
.bar-label {
  width: 190rpx;
  text-align: right;
  color: var(--text-secondary);
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 24rpx;
  border-radius: 8rpx;
  background: var(--bg-page);
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: var(--brand);
  border-radius: 0 8rpx 8rpx 0;
}
.bar-value {
  width: 60rpx;
  font-weight: 600;
}

.qa {
  margin-bottom: 24rpx;
}
.qa:last-child {
  margin-bottom: 0;
}
.qa-text {
  font-size: 25rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.theme {
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  background: var(--bg-page);
  margin-bottom: 12rpx;
}
.theme-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 25rpx;
}
.theme-title {
  font-weight: 600;
}
.theme-count {
  color: var(--brand);
  font-weight: 600;
  font-size: 24rpx;
}
.theme-note {
  font-size: 23rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.theme-foot {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.admin-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.admin-entry-title {
  font-size: 27rpx;
  font-weight: 600;
}
.admin-entry-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.map-foot {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 24rpx;
}
