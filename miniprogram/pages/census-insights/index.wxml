<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <block wx:if="{{block}}">
      <view class="card">
        <view class="hero-num">{{block.registered}} <text class="hero-sub">人已参与</text></view>
        <!-- 署名调研三不变量之二：亮明发起方、结果对全小区公开（第三个是管理员审核） -->
        <view class="hero-sign" wx:if="{{block.initiatorParty}}"
          >由 {{block.initiatorParty.label}} · {{block.initiatorParty.name}} 发起，聚合结果对全小区公开</view
        >
        <view class="hero-cap" wx:if="{{block.purpose}}">{{block.purpose}}</view>
        <view class="hero-cap" wx:if="{{block.pitch}}">{{block.pitch}}</view>
      </view>

      <!-- 我的问卷入口固定在聚合内容前，不必滑到页面底部 -->
      <view class="card my-registration-entry" wx:if="{{block.myAnswered}}" hover-class="frow-hover" bind:tap="goMyRegistration">
        <view>
          <view class="my-registration-title">查看我的问卷</view>
          <view class="my-registration-sub">已回答 {{block.myAnswered}} 题 · 查看答案和 AI 总结</view>
        </view>
        <text class="frow-arrow">›</text>
      </view>
      <t-button
        wx:elif="{{block.state === 'open'}}"
        theme="primary"
        block
        size="large"
        style="width: 100%; margin-bottom: 24rpx"
        bind:tap="goCensusForm"
      >参与问卷</t-button>

      <block wx:for="{{block.sections}}" wx:for-item="section" wx:key="title">
        <view class="card stats-section" wx:if="{{section.questions.length}}">
          <view class="stats-section-head" data-index="{{index}}" bind:tap="toggleSection">
            <view>
              <view class="stats-section-title">{{section.title}}</view>
              <view class="stats-section-count">{{section.questions.length}} 题</view>
            </view>
            <text class="stats-section-arrow {{section.expanded ? 'stats-section-arrow-open' : ''}}">›</text>
          </view>
          <view wx:if="{{section.expanded}}" class="stats-section-content">
            <view class="qa" wx:for="{{section.questions}}" wx:for-item="question" wx:key="text">
              <view class="qa-text">{{question.text}}</view>
              <view class="bar" wx:for="{{question.bars}}" wx:key="label">
                <view class="bar-label">{{item.label}}</view>
                <view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%"></view></view>
                <view class="bar-value">{{item.count}}</view>
              </view>
              <!-- 填空题：管理员归纳后的匿名主题（原文永不公示） -->
              <view class="theme" wx:for="{{question.themes}}" wx:for-item="theme" wx:key="title">
                <view class="theme-head">
                  <text class="theme-title">{{theme.title}}</text>
                  <text class="theme-count">{{theme.count}} 条</text>
                </view>
                <view class="theme-note" wx:if="{{theme.note}}">{{theme.note}}</view>
              </view>
              <view class="theme-foot" wx:if="{{question.themes.length}}"
                >归纳自 {{block.registered}} 份问卷的文字反馈</view
              >
            </view>
          </view>
        </view>
      </block>

      <!-- 发起者本人入口：邻居主动勾选授权给你看的问卷明细 -->
      <view class="card admin-entry" wx:if="{{block.isInitiator}}" hover-class="frow-hover" bind:tap="goConsented">
        <view>
          <view class="admin-entry-title">邻居授权给你看的问卷</view>
          <view class="admin-entry-sub">勾选了「让发起者看到我的问卷」的邻居 · 含联系方式与逐题回答</view>
        </view>
        <text class="frow-arrow">›</text>
      </view>

      <view class="card admin-entry" wx:if="{{showTextAdmin}}" hover-class="frow-hover" bind:tap="goTextAdmin">
        <view>
          <view class="admin-entry-title">文本题明细与归纳</view>
          <view class="admin-entry-sub">仅管理员可见 · 浏览文字反馈，归纳后可发布到本页</view>
        </view>
        <text class="frow-arrow">›</text>
      </view>
    </block>
  </page-status>

  <!-- AI 答疑半屏面板：page-container 原生支持返回手势关闭 -->
  <page-container
    show="{{aiChatShow}}"
    position="bottom"
    round
    custom-style="height: 82vh;"
    bind:beforeleave="onAiChatLeave"
    bind:leave="onAiChatLeave"
  >
    <ai-chat-panel id="aiChat" />
  </page-container>
</view>
