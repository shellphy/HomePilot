<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 前置门槛：该征集要求档案完整，先去个人资料补全 -->
    <block wx:if="{{needProfile}}">
      <view class="card gate">
        <view class="gate-title">参与前先完善个人资料</view>
        <view class="gate-sub">填写前需要先选好楼栋号并授权手机号，可在「我的 · 个人资料」里随时修改。</view>
        <t-button theme="primary" block size="large" style="width: 100%" bind:tap="goProfile">去完善资料</t-button>
      </view>
    </block>

    <block wx:elif="{{current}}">
      <view class="ai-report-preview" wx:if="{{moduleIndex === 0}}">
        <view class="ai-preview-head">
          <view class="ai-preview-mark">AI</view>
          <view>
            <view class="ai-preview-title">答完后，AI 帮你整理问卷总结</view>
            <view class="ai-preview-sub">根据你的回答生成个人总结</view>
          </view>
        </view>
      </view>

      <view class="step-bar">
        <view class="step-text">{{current.title}} · {{moduleIndex + 1}} / {{modules.length}}</view>
        <view class="meter step-meter">
          <view class="meter-fill" style="width: {{(moduleIndex + 1) / modules.length * 100}}%"></view>
        </view>
        <view wx:if="{{current.intro}}" class="step-intro">{{current.intro}}</view>
      </view>

      <view class="card question-card" wx:for="{{current.questions}}" wx:for-item="question" wx:for-index="questionIndex" wx:key="key">
        <view class="q-head">
          <text class="q-index">{{questionIndex + 1}}</text>
          <view class="q-title">
            {{question.text}}
            <text wx:if="{{question.type === 'multi'}}" class="q-note">可多选</text>
          </view>
        </view>
        <!-- 疑问冒头就地问：题面直传给 AI，不懂这道题不用退出去查 -->
        <view class="ask-ai" data-qkey="{{question.key}}" data-text="{{question.text}}" bind:tap="askQuestion">不懂这道题？问 AI</view>
        <view wx:if="{{question.note}}" class="q-explain">{{question.note}}</view>
        <textarea
          wx:if="{{question.type === 'text'}}"
          class="fin farea"
          auto-height
          maxlength="500"
          value="{{answers[question.key]}}"
          data-qkey="{{question.key}}"
          bind:input="onText"
        />
        <!-- 带选项解释的题：竖排选项行，解释写在选项下方（填写过程就是建概念） -->
        <view wx:elif="{{question.hasNotes}}" class="opts">
          <view
            wx:for="{{question.optionRows}}"
            wx:for-item="option"
            wx:key="label"
            class="opt {{picked[question.key + '::' + option.label] ? 'opt-on' : ''}}"
            data-qkey="{{question.key}}"
            data-qtype="{{question.type}}"
            data-value="{{option.label}}"
            bind:tap="pick"
          >
            <view class="opt-label">{{option.label}}</view>
            <view class="opt-note" wx:if="{{option.note}}">{{option.note}}</view>
          </view>
        </view>
        <view wx:else class="chips">
          <view
            wx:for="{{question.options}}"
            wx:for-item="option"
            wx:key="*this"
            class="chip {{picked[question.key + '::' + option] ? 'chip-on' : ''}}"
            data-qkey="{{question.key}}"
            data-qtype="{{question.type}}"
            data-value="{{option}}"
            bind:tap="pick"
          >{{option}}</view>
        </view>
      </view>

      <view class="nav-btns">
        <t-button wx:if="{{moduleIndex > 0}}" theme="light" size="large" style="flex: 1" bind:tap="prev">上一步</t-button>
        <t-button theme="primary" size="large" style="flex: 2" loading="{{submitting}}" bind:tap="next">{{moduleIndex + 1 < modules.length ? '下一模块' : '完成'}}</t-button>
      </view>
    </block>
  </page-status>

  <!-- AI 答疑半屏面板：page-container 原生支持返回手势关闭 -->
  <page-container
    show="{{aiChatShow}}"
    position="bottom"
    round
    custom-style="height: 82vh;"
    bind:beforeleave="onAiChatLeave"
    bind:leave="onAiChatLeave"
  >
    <ai-chat-panel id="aiChat" />
  </page-container>
</view>
