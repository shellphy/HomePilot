.gate {
  text-align: center;
  padding: 48rpx 36rpx;
}
.gate-title {
  font-size: 30rpx;
  font-weight: 600;
}
.gate-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 14rpx 0 28rpx;
}

.step-bar {
  padding: 4rpx 8rpx 24rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
}

/* 按钮的 flex 占比走 style 直传（外部 class 在 virtualHost 组件上不可靠） */
.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.skip-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 20rpx;
}
