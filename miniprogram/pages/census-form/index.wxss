.gate {
  text-align: center;
  padding: 48rpx 36rpx;
}
.gate-title {
  font-size: 30rpx;
  font-weight: 600;
}
.gate-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 14rpx 0 28rpx;
}

.ai-report-preview {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #176bff 0%, #7258e8 100%);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(38, 86, 204, 0.16);
}
.ai-report-preview::after {
  position: absolute;
  top: -70rpx;
  right: -50rpx;
  width: 190rpx;
  height: 190rpx;
  content: '';
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.ai-preview-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}
.ai-preview-mark {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  color: #335bd6;
  text-align: center;
  background: #ffffff;
  border-radius: 18rpx;
}
.ai-preview-title {
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.45;
}
.ai-preview-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.78);
}
.step-bar {
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
  background: var(--brand-bg);
  border-left: 6rpx solid var(--brand);
  border-radius: 16rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
  line-height: 1.6;
}

.question-card {
  padding: 28rpx;
  border: 1rpx solid #e2e7e3;
  box-shadow: 0 4rpx 16rpx rgba(25, 54, 38, 0.04);
}
.q-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}
.q-index {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
  color: #ffffff;
  text-align: center;
  background: var(--brand);
  border-radius: 50%;
}
.q-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.55;
  margin-bottom: 0;
}
.question-card .q-explain {
  padding: 14rpx 18rpx;
  margin-bottom: 18rpx;
  color: var(--text-secondary);
  background: #f7f8f7;
  border-radius: 12rpx;
}
.question-card .q-note {
  display: inline-block;
  padding: 2rpx 10rpx;
  color: var(--text-secondary);
  background: #eef1ef;
  border-radius: 999rpx;
}
.question-card .chips {
  gap: 14rpx;
}
.question-card .chip {
  background: #fafbfa;
  border-color: #dfe5e1;
}
.question-card .chip-on {
  color: var(--brand-deep);
  background: var(--brand-bg);
  border: 2rpx solid var(--brand);
}


/* 按钮的 flex 占比走 style 直传（外部 class 在 virtualHost 组件上不可靠） */
.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

/* 每道题的「问 AI」入口：轻量小字，不抢答题主线 */
.ask-ai {
  display: inline-block;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: var(--info);
  background: var(--info-bg);
  border-radius: 999rpx;
  margin: 12rpx 0 18rpx 54rpx;
}

/* 带解释的选项：竖排行，配色语义与 chip 一致 */
.opts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.opt {
  border: 1rpx solid #dfe5e1;
  background: #fafbfa;
  border-radius: 16rpx;
  padding: 18rpx 26rpx;
}
.opt-on {
  background: var(--brand-bg);
  border: 2rpx solid var(--brand);
}
.opt-label {
  font-size: 26rpx;
}
.opt-on .opt-label {
  color: var(--brand-deep);
  font-weight: 600;
}
.opt-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}
