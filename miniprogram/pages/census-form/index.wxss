.gate {
  text-align: center;
  padding: 48rpx 36rpx;
}
.gate-title {
  font-size: 30rpx;
  font-weight: 600;
}
.gate-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 14rpx 0 28rpx;
}

.step-bar {
  padding: 4rpx 8rpx 24rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
}

/* 按钮的 flex 占比走 style 直传（外部 class 在 virtualHost 组件上不可靠） */
.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.skip-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 20rpx;
}

/* 带解释的选项：竖排行，配色语义与 chip 一致 */
.opts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.opt {
  border: 1rpx solid var(--line);
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 18rpx 26rpx;
}
.opt-on {
  background: var(--brand-bg);
  border-color: var(--brand);
}
.opt-label {
  font-size: 26rpx;
}
.opt-on .opt-label {
  color: var(--brand-deep);
  font-weight: 600;
}
.opt-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}
