.gate {
  text-align: center;
  padding: 48rpx 36rpx;
}
.gate-title {
  font-size: 30rpx;
  font-weight: 600;
}
.gate-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 14rpx 0 28rpx;
}

.ai-report-preview {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #176bff 0%, #7258e8 100%);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 36rpx rgba(38, 86, 204, 0.22);
}
.ai-report-preview::after {
  position: absolute;
  top: -70rpx;
  right: -50rpx;
  width: 190rpx;
  height: 190rpx;
  content: '';
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.ai-preview-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}
.ai-preview-mark {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  color: #335bd6;
  text-align: center;
  background: #ffffff;
  border-radius: 18rpx;
}
.ai-preview-title {
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.45;
}
.ai-preview-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.78);
}
.ai-preview-points {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}
.ai-preview-points text {
  padding: 8rpx 14rpx;
  font-size: 21rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}
.ai-preview-foot {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.step-bar {
  padding: 4rpx 8rpx 24rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
}

/* 末模块的授权勾选：明确是把匿名破例给具体发起方看，默认关 */
.consent {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 16rpx;
}
.consent-box {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid var(--line-dark);
  border-radius: 10rpx;
  color: #fff;
  font-size: 26rpx;
  text-align: center;
  line-height: 40rpx;
}
.consent-box-on {
  background: var(--brand);
  border-color: var(--brand);
}
.consent-title {
  font-size: 26rpx;
  font-weight: 600;
}
.consent-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
  margin-top: 6rpx;
}

/* 按钮的 flex 占比走 style 直传（外部 class 在 virtualHost 组件上不可靠） */
.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.skip-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 20rpx;
}

/* 每道题的「问 AI」入口：轻量小字，不抢答题主线 */
.ask-ai {
  display: inline-block;
  font-size: 22rpx;
  color: var(--brand);
  margin: 6rpx 0 16rpx;
}

/* 带解释的选项：竖排行，配色语义与 chip 一致 */
.opts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.opt {
  border: 1rpx solid var(--line);
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 18rpx 26rpx;
}
.opt-on {
  background: var(--brand-bg);
  border-color: var(--brand);
}
.opt-label {
  font-size: 26rpx;
}
.opt-on .opt-label {
  color: var(--brand-deep);
  font-weight: 600;
}
.opt-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}
