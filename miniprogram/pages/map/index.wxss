.hero-num {
  font-size: 56rpx;
  font-weight: 700;
}
.hero-sub {
  font-size: 26rpx;
  font-weight: 400;
  color: #9b978c;
}
.hero-cap {
  font-size: 24rpx;
  color: #6e6b63;
  margin: 6rpx 0 20rpx;
}

.bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
  font-size: 24rpx;
}
.bar:last-child {
  margin-bottom: 0;
}
.bar-label {
  width: 190rpx;
  text-align: right;
  color: #6e6b63;
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 24rpx;
  border-radius: 8rpx;
  background: #f6f6f3;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: #06ae56;
  border-radius: 0 8rpx 8rpx 0;
}
.bar-value {
  width: 60rpx;
  font-weight: 600;
}

.map-foot {
  text-align: center;
  font-size: 22rpx;
  color: #9b978c;
  padding-top: 24rpx;
}
