<view class="page-body tabbed">
  <block wx:if="{{loaded}}">
    <view class="card">
      <view class="hero-num">{{registered}} <text class="hero-sub">/ {{totalHouseholds}} 户已登记</text></view>
      <view class="hero-cap">登记越多，团购谈判筹码越足</view>
      <view class="meter">
        <view class="meter-fill" style="width: {{registeredPercent}}%"></view>
      </view>
    </view>

    <view class="card" wx:if="{{layouts.length}}">
      <view class="kicker">户型分布</view>
      <view class="bar" wx:for="{{layouts}}" wx:key="label">
        <view class="bar-label">{{item.label}}</view>
        <view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%"></view></view>
        <view class="bar-value">{{item.count}}</view>
      </view>
    </view>

    <view class="card" wx:if="{{decorationModes.length}}">
      <view class="kicker">装修方式</view>
      <view class="bar" wx:for="{{decorationModes}}" wx:key="label">
        <view class="bar-label">{{item.label}}</view>
        <view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%"></view></view>
        <view class="bar-value">{{item.count}}</view>
      </view>
    </view>

    <view class="card" wx:if="{{interests.length}}">
      <view class="kicker">团购意向 · 感兴趣户数</view>
      <view class="bar" wx:for="{{interests}}" wx:key="label">
        <view class="bar-label">{{item.label}}</view>
        <view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%"></view></view>
        <view class="bar-value">{{item.count}}</view>
      </view>
    </view>

    <t-button theme="primary" block size="large" bind:tap="goRegistration">完善我的登记</t-button>
    <view class="map-foot">数据来自 {{registered}} 份登记 · 明细仅团长可见</view>
  </block>

  <view wx:elif="{{loadError}}" class="hint" bind:tap="loadStats">
    {{loadError}}
    <view class="hint-retry">点击重试</view>
  </view>
  <view wx:else class="hint">加载中…</view>
</view>
