<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card form-list">
      <!-- 头像行：整行是 chooseAvatar 按钮，头像靠右贴箭头 -->
      <button class="frow frow-btn" hover-class="frow-hover" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <text class="frow-label">头像</text>
        <image wx:if="{{avatar}}" class="avatar" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-fallback"></view>
        <text class="frow-arrow">›</text>
      </button>

      <view class="frow">
        <text class="frow-label">昵称</text>
        <input
          class="frow-input"
          type="nickname"
          value="{{nickname}}"
          placeholder="请填写"
          data-field="nickname"
          bind:input="onInput"
          bind:blur="onInput"
          bind:change="onInput"
        />
      </view>

      <!-- 手机号只能微信授权获取（不接受手填），业主与相关方通用 -->
      <button class="frow frow-btn" hover-class="frow-hover" open-type="getPhoneNumber" bind:getphonenumber="onGetPhone">
        <text class="frow-label">手机号</text>
        <text class="frow-value">{{phone || '点击授权微信手机号'}}</text>
        <text class="frow-arrow">›</text>
      </button>

      <view class="frow" hover-class="frow-hover" bind:tap="chooseIdentity">
        <text class="frow-label">身份</text>
        <text class="frow-value">{{identityLabel}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <!-- 业主 -->
      <block wx:if="{{identity === 'resident'}}">
        <picker mode="selector" range="{{buildings}}" value="{{buildingIndex < 0 ? 0 : buildingIndex}}" bind:change="onPickBuilding">
          <view class="frow" hover-class="frow-hover">
            <text class="frow-label">楼栋号<text class="f-required">*</text></text>
            <text class="frow-value">{{unitLabel || '请选择'}}</text>
            <text class="frow-arrow">›</text>
          </view>
        </picker>
        <view class="frow">
          <text class="frow-label">房号</text>
          <input class="frow-input" value="{{roomLabel}}" placeholder="如 1802" data-field="roomLabel" bind:input="onInput" />
        </view>
      </block>

      <!-- 商家/物业等相关方：名称通用，补充字段（如商家主营）由类型元数据决定 -->
      <block wx:else>
        <view class="frow">
          <text class="frow-label">名称<text class="f-required">*</text></text>
          <input class="frow-input" value="{{partyName}}" placeholder="{{identityMeta.name_hint || '请填写'}}" data-field="partyName" bind:input="onInput" />
        </view>
        <view class="frow" wx:if="{{identityMeta.category_label}}">
          <text class="frow-label">{{identityMeta.category_label}}</text>
          <input class="frow-input" value="{{partyCategory}}" placeholder="如 门窗、全屋定制" data-field="partyCategory" bind:input="onInput" />
        </view>
        <view class="frow">
          <text class="frow-label">简介</text>
          <input class="frow-input" value="{{partyIntro}}" placeholder="一句话介绍，显示在名录和详情页" data-field="partyIntro" bind:input="onInput" maxlength="60" />
        </view>
      </block>
    </view>

    <!-- 相关方详情页素材：详细介绍 + 照片，各类型统一字段、内容自由发挥 -->
    <block wx:if="{{identity !== 'resident'}}">
      <view class="card">
        <view class="q-title">详细介绍</view>
        <textarea class="fin farea" placeholder="{{identityMeta.description_hint || '想让邻居知道的都可以写在这里'}}" value="{{partyDescription}}" data-field="partyDescription" bind:input="onInput" maxlength="2000" />
      </view>
      <view class="card">
        <view class="q-title">照片<text class="q-note">门头、资质、服务现场…最多 9 张</text></view>
        <view class="shots">
          <view class="shot-wrap" wx:for="{{partyImages}}" wx:key="*this">
            <image class="shot" src="{{item}}" mode="aspectFill" data-url="{{item}}" bind:tap="previewImage" />
            <view class="shot-del" data-index="{{index}}" catch:tap="removeImage">✕</view>
          </view>
          <view class="shot-add" bind:tap="chooseImages">{{uploading ? '上传中…' : '+'}}</view>
        </view>
      </view>
    </block>

    <view class="privacy">手机号和房号仅管理员可见，用于必要时联系；不会出现在任何公示名单里。</view>
    <view class="privacy" wx:if="{{identity === 'merchant'}}">相关方身份对全小区公开。商家经管理员认证后可发起团购和活动（带「已认证」标识）并进入商家名录；相关方不参与业主接龙，可随时切回业主身份。</view>
    <view class="privacy" wx:elif="{{identity !== 'resident'}}">相关方身份对全小区公开。物业/开发商/业委会经管理员认证后，可在事项进展里发布官方回应；相关方不参与业主接龙，可随时切回业主身份。</view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" loading="{{submitting}}" bind:tap="submit">保存</t-button>
    </view>
  </page-status>
</view>
