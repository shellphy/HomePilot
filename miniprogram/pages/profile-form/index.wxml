<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card form-list">
      <!-- 头像行：整行是 chooseAvatar 按钮，头像靠右贴箭头 -->
      <button class="frow frow-btn" hover-class="frow-hover" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <text class="frow-label">头像</text>
        <image wx:if="{{avatar}}" class="avatar" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-fallback"></view>
        <text class="frow-arrow">›</text>
      </button>

      <view class="frow">
        <text class="frow-label">昵称</text>
        <input
          class="frow-input"
          type="nickname"
          value="{{nickname}}"
          data-field="nickname"
          bind:input="onInput"
          bind:blur="onInput"
          bind:change="onInput"
        />
      </view>

      <!-- 手机号：手填或微信授权预填皆可，业主与相关方通用；点保存才写入 -->
      <!-- 授权按钮放标签右侧，输入框始终 flex 到行尾右对齐，与其余行的值对齐一致 -->
      <view class="frow">
        <text class="frow-label">手机号</text>
        <button class="frow-inline-btn" open-type="getPhoneNumber" bind:getphonenumber="onGetPhone">微信授权</button>
        <input
          class="frow-input"
          type="number"
          value="{{phone}}"
          data-field="phone"
          bind:input="onInput"
          placeholder="手动填写"
        />
      </view>

      <view class="frow" hover-class="frow-hover" bind:tap="chooseIdentity">
        <text class="frow-label">身份</text>
        <text class="frow-value">{{identityLabel}}</text>
        <text class="frow-arrow">›</text>
      </view>

      <!-- 业主 -->
      <block wx:if="{{identity === 'resident'}}">
        <picker mode="selector" range="{{buildings}}" value="{{buildingIndex < 0 ? 0 : buildingIndex}}" bind:change="onPickBuilding">
          <view class="frow" hover-class="frow-hover">
            <text class="frow-label">楼栋号<text class="f-required">*</text></text>
            <text class="frow-value">{{unitLabel || '请选择'}}</text>
            <text class="frow-arrow">›</text>
          </view>
        </picker>
        <picker mode="selector" range="{{layouts}}" value="{{layoutIndex < 0 ? 0 : layoutIndex}}" bind:change="onPickLayout">
          <view class="frow" hover-class="frow-hover">
            <text class="frow-label">户型</text>
            <text class="frow-value">{{layoutLabel || '请选择'}}</text>
            <text class="frow-arrow">›</text>
          </view>
        </picker>
        <view class="frow">
          <text class="frow-label">房号<text class="f-optional">选填</text></text>
          <input class="frow-input" value="{{roomLabel}}" data-field="roomLabel" bind:input="onInput" />
        </view>
      </block>

      <!-- 商家/物业等相关方：名称通用，补充字段（如商家主营）由类型元数据决定 -->
      <block wx:else>
        <view class="frow">
          <text class="frow-label">名称<text class="f-required">*</text></text>
          <input class="frow-input" value="{{partyName}}" data-field="partyName" bind:input="onInput" />
        </view>
        <view class="frow" wx:if="{{identityMeta.category_label}}">
          <text class="frow-label">{{identityMeta.category_label}}</text>
          <input class="frow-input" value="{{partyCategory}}" data-field="partyCategory" bind:input="onInput" />
        </view>
        <view class="frow">
          <text class="frow-label">简介</text>
          <input class="frow-input" value="{{partyIntro}}" data-field="partyIntro" bind:input="onInput" maxlength="60" />
        </view>
      </block>
    </view>

    <!-- 相关方详情页素材：详细介绍 + 照片，各类型统一字段、内容自由发挥 -->
    <block wx:if="{{identity !== 'resident'}}">
      <view class="card">
        <view class="q-title">详细介绍</view>
        <textarea class="fin farea" value="{{partyDescription}}" data-field="partyDescription" bind:input="onInput" maxlength="2000" />
      </view>
      <view class="card">
        <view class="q-title">照片<text class="q-note">门头、资质、服务现场…最多 9 张</text></view>
        <view class="shots">
          <view class="shot-wrap" wx:for="{{partyImages}}" wx:key="*this">
            <image class="shot" src="{{item}}" mode="aspectFill" data-url="{{item}}" bind:tap="previewImage" />
            <view class="shot-del" data-index="{{index}}" catch:tap="removeImage">✕</view>
          </view>
          <view class="shot-add" bind:tap="chooseImages">{{uploading ? '上传中…' : '+'}}</view>
        </view>
      </view>
    </block>

    <view class="privacy">手机号和房号不会公示，仅必要时用于联系你。</view>
    <view class="privacy" wx:if="{{identity === 'merchant'}}">商家身份对全小区公开。通过核验后，你可以带「身份已核验」标识发起团购和活动，并进入商家名录；商家身份不参与业主接龙，想参与随时切回业主身份。</view>
    <view class="privacy" wx:elif="{{identity !== 'resident'}}">这个身份对全小区公开。通过核验后，你可以在事项进展里发布官方回应；这个身份不参与业主接龙，想参与随时切回业主身份。</view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit">保存</t-button>
    </view>
  </page-status>
</view>
