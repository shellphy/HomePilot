.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}
.chat-body {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}
.chat-tip {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.7;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.chat-empty {
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
  padding: 60rpx 40rpx;
  line-height: 1.8;
}
.bubble-row {
  display: flex;
  margin-bottom: 20rpx;
}
.bubble-row-me {
  justify-content: flex-end;
}
.bubble {
  max-width: 80%;
  padding: 18rpx 24rpx;
  border-radius: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  word-break: break-all;
}
.bubble-ai {
  background: #fff;
  color: var(--text-primary);
  border-top-left-radius: 6rpx;
}
.bubble-me {
  background: var(--brand);
  color: #fff;
  border-top-right-radius: 6rpx;
}
.bubble-typing {
  color: var(--text-muted);
}
.chat-quota {
  text-align: center;
  font-size: 22rpx;
  color: var(--warn);
  padding: 8rpx 0;
}
.chat-anchor {
  height: 2rpx;
}
.chat-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--line);
}
.chat-reset {
  flex-shrink: 0;
  font-size: 23rpx;
  color: var(--text-muted);
}
.chat-input {
  flex: 1;
  background: var(--bg-page);
  border-radius: 32rpx;
  padding: 14rpx 26rpx;
  font-size: 27rpx;
}
