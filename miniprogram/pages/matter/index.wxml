<view class="page-body detail-body" style="{{dockReserve ? 'padding-bottom:' + dockReserve + 'px' : ''}}">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <block wx:if="{{matter}}">
      <notice-detail wx:if="{{matter.type === 'notice'}}" matter="{{matter}}" />
      <groupbuy-detail
        wx:elif="{{matter.type === 'groupbuy'}}"
        matter="{{matter}}"
        joined="{{joined}}"
        is-initiator="{{isInitiator}}"
        my-review="{{myReview}}"
        contacts="{{contacts}}"
        contact-roster="{{contactRoster}}"
        initiator-contact="{{initiatorContact}}"
        is-party="{{isParty}}"
        party-label="{{partyLabel}}"
        my-share-contact="{{myShareContact}}"
        my-join-stage="{{myJoinStage}}"
        bind:refresh="reload"
        bind:dockmeasure="onDockMeasure"
      />
      <matter-detail
        wx:else
        matter="{{matter}}"
        joined="{{joined}}"
        is-initiator="{{isInitiator}}"
        my-review="{{myReview}}"
        can-respond="{{canRespond}}"
        is-party="{{isParty}}"
        party-label="{{partyLabel}}"
        contacts="{{contacts}}"
        initiator-contact="{{initiatorContact}}"
        my-share-contact="{{myShareContact}}"
        bind:refresh="reload"
        bind:dockmeasure="onDockMeasure"
      />

      <!-- 大家都在问：谁都能问、谁都能答，疑问沉淀给后来的人 -->
      <qa-panel
        matter="{{matter}}"
        bind:refresh="reload"
      />
    </block>
  </page-status>

  <!-- AI 答疑悬浮入口：固定在右下角，随吸底操作条高度上浮避让（仅已过审的团购/活动） -->
  <ai-quick-ask
    wx:if="{{aiChatEnabled && matter && matter.is_approved && (matter.type === 'groupbuy' || matter.type === 'activity')}}"
    matter-id="{{matter.id}}"
    matter-title="{{matter.title}}"
    questions="{{quickQuestions}}"
    bottom-offset="{{dockReserve}}"
  />

  <!-- AI 答疑半屏面板：page-container 原生支持返回手势关闭，业主不离开正在看的事项 -->
  <page-container
    show="{{aiChatShow}}"
    position="bottom"
    round
    custom-style="height: 82vh;"
    bind:beforeleave="onAiChatLeave"
    bind:leave="onAiChatLeave"
  >
    <ai-chat-panel id="aiChat" />
  </page-container>
</view>
