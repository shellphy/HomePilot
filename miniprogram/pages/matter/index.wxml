<view class="page-body detail-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <block wx:if="{{matter}}">
      <notice-detail wx:if="{{matter.type === 'notice'}}" matter="{{matter}}" />
      <groupbuy-detail
        wx:elif="{{matter.type === 'groupbuy'}}"
        matter="{{matter}}"
        joined="{{joined}}"
        is-initiator="{{isInitiator}}"
        my-review="{{myReview}}"
        contacts="{{contacts}}"
        initiator-contact="{{initiatorContact}}"
        bind:refresh="reload"
      />
      <matter-detail
        wx:else
        matter="{{matter}}"
        joined="{{joined}}"
        is-initiator="{{isInitiator}}"
        can-respond="{{canRespond}}"
        bind:refresh="reload"
      />
    </block>
  </page-status>
</view>
