<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card registration-summary">
      <view class="registration-summary-head">
        <view>
          <view class="registration-title">我的问卷</view>
          <view class="registration-count">已回答 {{answeredCount}} 题</view>
        </view>
        <view class="questionnaire-status">已提交</view>
      </view>
      <view class="questionnaire-actions">
        <view class="questionnaire-action" bind:tap="goAnswers">我的回答</view>
        <view class="questionnaire-action" bind:tap="goStats">整体数据</view>
        <view class="questionnaire-action" wx:if="{{censusState === 'open'}}" bind:tap="goEdit">修改问卷</view>
      </view>
    </view>

    <view class="content-heading ai-content-heading">
      <view>
        <view class="content-heading-title">AI 问卷总结</view>
        <view class="content-heading-sub">根据你的回答整理重点和待确认事项，只给你自己看</view>
      </view>
    </view>

    <block wx:if="{{!report}}">
      <view class="card report-generating" wx:if="{{generationStatus === 'pending'}}">
        <view class="report-generating-mark">AI</view>
        <view class="report-generating-copy">
          <view class="report-generating-title">正在生成报告中</view>
          <view class="report-generating-sub">生成需要一分多钟，完成后会自动显示，中途可以先去别的页面。</view>
        </view>
      </view>
      <view class="card report-empty" wx:else>
        <view class="empty-title">{{generationStatus === 'failed' ? '报告生成失败' : '生成我的问卷总结'}}</view>
        <view class="empty-copy">{{generationError || presentation.empty_description}}</view>
        <t-button theme="primary" block size="large" bind:tap="generate"
          >{{generationStatus === 'failed' ? '重新生成' : '生成报告'}}</t-button
        >
      </view>
    </block>

    <block wx:if="{{report}}">
      <view class="report-hero">
        <view class="report-kicker">{{presentation.profile_label}}</view>
        <view class="report-title">{{report.headline}}</view>
        <view class="report-overview">{{report.overview}}</view>
      </view>

      <view class="card" wx:if="{{report.priorities.length}}">
        <view class="section-title">优先守住</view>
        <view class="priority" wx:for="{{report.priorities}}" wx:key="title">
          <view class="item-title">{{index + 1}}. {{item.title}}</view>
          <view class="item-copy">{{item.reason}}</view>
          <view class="item-action">下一步：{{item.action}}</view>
        </view>
      </view>

      <view class="card" wx:if="{{report.decisions.length}}">
        <view class="section-title">已经形成的方向</view>
        <view class="decision" wx:for="{{report.decisions}}" wx:key="topic">
          <view class="decision-head"><text>{{item.topic}}</text><text class="choice">{{item.choice}}</text></view>
          <view class="item-copy">{{item.meaning}}</view>
        </view>
      </view>

      <view class="card warning-card" wx:if="{{report.risks.length}}">
        <view class="section-title">{{presentation.risk_label}}</view>
        <view class="bullet" wx:for="{{report.risks}}" wx:key="*this">• {{item}}</view>
      </view>

      <view class="card" wx:if="{{report.open_questions.length}}">
        <view class="section-title">还要确认</view>
        <view class="check" wx:for="{{report.open_questions}}" wx:key="*this"><text class="box"></text>{{item}}</view>
      </view>

      <view class="actions">
        <t-button theme="light" block size="large" bind:tap="askAi">继续问 AI</t-button>
        <t-button theme="light" block size="large" loading="{{generating}}" bind:tap="generate">按最新答案重新生成</t-button>
      </view>
    </block>
  </page-status>

  <page-container show="{{aiChatShow}}" position="bottom" round custom-style="height: 82vh;" bind:beforeleave="onAiChatLeave" bind:leave="onAiChatLeave">
    <ai-chat-panel id="aiChat" />
  </page-container>
</view>
