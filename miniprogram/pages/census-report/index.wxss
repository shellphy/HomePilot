.report-generating {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 30rpx;
  background: #f3f6ff;
  border: 1rpx solid #cfd8ff;
}
.report-generating-mark {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 58rpx;
  color: #ffffff;
  text-align: center;
  background: #516edb;
  border-radius: 16rpx;
}
.report-generating-copy {
  flex: 1;
}
.report-generating-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f4ca8;
}
.report-generating-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6673a1;
}
.report-empty { padding: 36rpx 28rpx; }
.empty-title { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.empty-copy { color: var(--text-secondary); font-size: 25rpx; line-height: 1.7; margin-bottom: 28rpx; }

.report-md {
  display: block;
  font-size: 27rpx;
  line-height: 1.75;
  color: var(--text-primary);
  word-break: break-word;
}

.actions { display: flex; gap: 16rpx; }
.actions t-button { flex: 1; }
