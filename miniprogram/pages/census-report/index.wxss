.registration-summary {
  padding: 30rpx;
  border: 1rpx solid var(--brand);
  background: linear-gradient(145deg, #ffffff, var(--brand-bg));
}
.registration-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}
.registration-title {
  font-size: 32rpx;
  font-weight: 700;
}
.registration-count,
.registration-module-count {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}
.questionnaire-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  font-size: 21rpx;
  font-weight: 600;
  color: var(--brand-deep);
  background: #ffffff;
  border: 1rpx solid var(--brand);
  border-radius: 999rpx;
}
.questionnaire-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.questionnaire-action {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-deep);
  text-align: center;
  background: #ffffff;
  border: 1rpx solid var(--brand);
  border-radius: 14rpx;
}
.registration-module {
  padding: 0;
  overflow: hidden;
  border: 1rpx solid #e3e8e4;
  box-shadow: none;
}
.registration-module-open {
  border-color: #b7ddc8;
}
.registration-module-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 104rpx;
  padding: 0 28rpx;
  background: #fafcfb;
}
.registration-module-open .registration-module-head {
  background: var(--brand-bg);
}
.registration-module-title {
  flex: 1;
  font-size: 27rpx;
  font-weight: 600;
}
.registration-module-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}
.registration-arrow {
  width: 42rpx;
  height: 42rpx;
  font-size: 34rpx;
  line-height: 38rpx;
  color: var(--text-secondary);
  text-align: center;
  background: #ffffff;
  border-radius: 50%;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}
.registration-arrow-open {
  transform: rotate(-90deg);
}
.registration-answers {
  padding: 8rpx 24rpx 16rpx;
  background: #ffffff;
  border-top: 1rpx solid #dcebe2;
}
.registration-answer {
  padding: 20rpx;
  margin-top: 14rpx;
  background: var(--bg-page);
  border-radius: 14rpx;
}
.registration-question-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.registration-question-index {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  color: var(--text-secondary);
  text-align: center;
  background: #ffffff;
  border-radius: 50%;
}
.registration-question {
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}
.registration-value {
  margin: 10rpx 0 0 46rpx;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.55;
  color: var(--text-primary);
}
.content-heading {
  padding: 14rpx 8rpx 16rpx;
}
.content-heading-title {
  font-size: 28rpx;
  font-weight: 700;
}
.content-heading-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}
.answers-content-heading {
  margin-top: 12rpx;
}
.report-generating {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 30rpx;
  background: #f3f6ff;
  border: 1rpx solid #cfd8ff;
}
.report-generating-mark {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 58rpx;
  color: #ffffff;
  text-align: center;
  background: #516edb;
  border-radius: 16rpx;
}
.report-generating-copy {
  flex: 1;
}
.report-generating-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f4ca8;
}
.report-generating-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6673a1;
}
.report-empty { padding: 36rpx 28rpx; }
.empty-title { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.empty-copy { color: var(--text-secondary); font-size: 25rpx; line-height: 1.7; margin-bottom: 28rpx; }
.report-hero { margin: 0 -24rpx 24rpx; padding: 40rpx 32rpx; color: #fff; background: linear-gradient(145deg, #087f5b, #06ae56); }
.report-kicker { font-size: 22rpx; opacity: .8; letter-spacing: 3rpx; }
.report-title { font-size: 40rpx; font-weight: 700; line-height: 1.25; margin: 12rpx 0; }
.report-overview { font-size: 25rpx; line-height: 1.65; opacity: .94; }
.section-title { font-size: 29rpx; font-weight: 700; margin-bottom: 20rpx; }
.priority, .decision { padding: 18rpx 0; border-bottom: 1rpx solid var(--line); }
.priority:last-child, .decision:last-child { border-bottom: 0; padding-bottom: 0; }
.item-title { font-size: 27rpx; font-weight: 650; }
.item-copy { color: var(--text-secondary); font-size: 24rpx; line-height: 1.6; margin-top: 6rpx; }
.item-action { background: var(--brand-bg); color: var(--brand-deep); border-radius: 10rpx; padding: 12rpx 16rpx; font-size: 23rpx; margin-top: 10rpx; }
.decision-head { display: flex; justify-content: space-between; gap: 18rpx; font-size: 25rpx; font-weight: 600; }
.choice { color: var(--brand-deep); text-align: left; }
.warning-card { border-left: 6rpx solid #e09f3e; }
.merchant-card { border: 1rpx solid var(--brand); }
.bullet { font-size: 25rpx; line-height: 1.65; margin-bottom: 10rpx; }
.check { display: flex; gap: 12rpx; font-size: 25rpx; line-height: 1.55; margin-bottom: 14rpx; }
.box { width: 25rpx; height: 25rpx; border: 2rpx solid var(--text-muted); border-radius: 5rpx; flex-shrink: 0; margin-top: 5rpx; }
.privacy, .shared-foot { color: var(--text-muted); font-size: 22rpx; line-height: 1.55; margin-top: 20rpx; }
.actions { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.revoke { text-align: center; color: var(--danger, #c2413b); font-size: 23rpx; padding: 10rpx; }
.shared-foot { text-align: center; padding: 8rpx 20rpx 32rpx; }
