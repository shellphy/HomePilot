.report-empty { padding: 36rpx 28rpx; }
.empty-title { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.empty-copy { color: var(--text-secondary); font-size: 25rpx; line-height: 1.7; margin-bottom: 28rpx; }

.report-md {
  display: block;
  font-size: 27rpx;
  line-height: 1.75;
  color: var(--text-primary);
  word-break: break-word;
}

.report-by {
  margin: 12rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
}

.actions { display: flex; gap: 16rpx; }
.actions t-button { flex: 1; }
