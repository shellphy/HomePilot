<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 短字段统一行式（标签左、值右），与管理端表单同一套格式 -->
    <view class="card form-list">
      <view class="frow">
        <text class="frow-label">标题<text class="f-required">*</text></text>
        <input class="frow-input" placeholder="{{copy.titlePlaceholder}}" value="{{title}}" data-field="title" bind:input="onInput" />
      </view>
      <view class="frow">
        <text class="frow-label">目标数<text class="q-note">{{copy.targetHint}}</text></text>
        <input class="frow-input" type="number" placeholder="不填则不设目标" value="{{targetCount}}" data-field="targetCount" bind:input="onInput" />
      </view>
    </view>

    <view class="card">
      <view class="q-title">把事情说清楚<text class="f-required">*</text></view>
      <textarea class="fin farea" auto-height placeholder="{{copy.pitchPlaceholder}}" value="{{pitch}}" data-field="pitch" bind:input="onInput" maxlength="1000" />
    </view>

    <view class="privacy">发起即成为这件事的牵头人，负责更新进展。参与名单以「楼栋 + 昵称」对全小区公示。</view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" loading="{{submitting}}" bind:tap="submit">{{id ? '保存' : '提交审核'}}</t-button>
    </view>
  </page-status>
</view>
