<view class="page-body tabbed">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
  <block wx:if="{{me}}">
    <!-- 头部：头像昵称直接融在淡渐变页面背景上（常规「我的」页结构） -->
    <view class="hero-bg"></view>
    <!-- 整行都是资料入口，头像在这里只是展示（编辑在内页） -->
    <view class="profile" hover-class="profile-hover" bind:tap="goProfile">
      <image wx:if="{{me.avatar}}" class="avatar" src="{{me.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-fallback"></view>
      <view class="profile-main">
        <view class="profile-name">{{me.nickname || '未设置昵称'}}</view>
        <view class="profile-sub" wx:if="{{identityLine}}">{{identityLine}}</view>
      </view>
      <text class="profile-arrow">›</text>
    </view>

    <!-- 相关方认证状态：入驻后一眼看到审核进展，未通过可直接去改资料重交 -->
    <view class="list" wx:if="{{me.party}}">
      <view class="row" hover-class="row-hover" bind:tap="goPartyStatus">
        <text class="row-title">{{me.party.label}}认证</text>
        <view class="row-right">
          <text class="row-note {{me.party.review_status === 'rejected' ? 'row-note-todo' : ''}}">{{partyStatusNote}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 固定三行：参与 / 牵头 / 问卷 -->
    <view class="list">
      <view class="row" hover-class="row-hover" bind:tap="goJoined">
        <text class="row-title">我参与的</text>
        <view class="row-right">
          <view class="row-dot" wx:if="{{me.has_joined_updates}}"></view>
          <text class="row-note">{{joinedCount}} 件</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goMine">
        <text class="row-title">我牵头的</text>
        <view class="row-right">
          <view class="row-dot" wx:if="{{me.has_mine_updates}}"></view>
          <text class="row-note">{{mineCount}} 件</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goCensus">
        <text class="row-title">我的问卷</text>
        <view class="row-right">
          <text class="row-note">{{censusCount}} 份</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 管理员功能（is_admin 由 admin:grant 授权），直接平铺不做二级入口 -->
    <view class="list" wx:if="{{me.is_admin}}">
      <view class="row" hover-class="row-hover" bind:tap="goAdminMatters">
        <text class="row-title">全部事项</text>
        <view class="row-right">
          <!-- 待办是「有活要干」，不能和普通计数一样淡 -->
          <text class="row-note {{pendingCount ? 'row-note-todo' : ''}}">{{pendingCount ? pendingCount + ' 件待审核' : ''}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goAdminParties">
        <text class="row-title">相关方认证</text>
        <view class="row-right">
          <text class="row-note {{partyPendingCount ? 'row-note-todo' : ''}}">{{partyPendingCount ? partyPendingCount + ' 家待认证' : ''}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row" hover-class="row-hover" bind:tap="goAdminSettings">
        <text class="row-title">社区设置</text>
        <view class="row-right">
          <text class="row-arrow">›</text>
        </view>
      </view>
      <!-- 管理员管理：只有超级管理员能增减管理员 -->
      <view class="row" wx:if="{{me.is_super_admin}}" hover-class="row-hover" bind:tap="goAdminUsers">
        <text class="row-title">管理员</text>
        <view class="row-right">
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>

  </block>
  </page-status>
</view>
