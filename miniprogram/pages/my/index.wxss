/* 顶部淡渐变背景：融进页面，不是色块卡片 */
.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(180deg, #dcf1e5 0%, rgba(246, 246, 243, 0) 100%);
  pointer-events: none;
}

.profile {
  position: relative;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 48rpx 12rpx 44rpx;
  text-align: left;
}
.profile-hover {
  opacity: 0.7;
}
.avatar {
  display: block;
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.avatar-fallback {
  background: #ffffff;
  line-height: 124rpx;
  text-align: center;
  color: var(--brand-deep);
  font-size: 44rpx;
  font-weight: 700;
}
.profile-main {
  flex: 1;
  min-width: 0;
}
.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.profile-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.profile-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: var(--line-dark);
  padding-right: 8rpx;
}

/* 数据栏 */
.stats {
  position: relative;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}
.stat {
  flex: 1;
  text-align: center;
}
.stat-hover {
  opacity: 0.55;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}
.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 列表：大行高 + 细分割线 */
.list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  height: 120rpx;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.55;
}
.row-title {
  font-size: 30rpx;
  color: var(--text-primary);
}
.row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}
.row-note {
  font-size: 26rpx;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.row-arrow {
  font-size: 36rpx;
  line-height: 1;
  color: var(--line-dark);
  flex-shrink: 0;
}

