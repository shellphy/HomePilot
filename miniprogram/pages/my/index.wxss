.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-btn {
  padding: 0;
  margin: 0;
  width: 112rpx;
  height: 112rpx;
  min-height: 0;
  border: none;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.avatar-btn::after {
  border: none;
}
.avatar-img {
  display: block;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
}
.avatar-fallback {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--brand-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand-deep);
  font-size: 40rpx;
  font-weight: 700;
}
.profile-main {
  flex: 1;
  min-width: 0;
}
.nickname-input {
  font-size: 30rpx;
  font-weight: 600;
  padding: 4rpx 0;
}
.profile-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.reg-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
}
.reg-label {
  color: var(--text-secondary);
}
.reg-row-tags {
  align-items: flex-start;
}
.reg-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: flex-end;
  max-width: 70%;
}
.reg-actions {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.reg-btn {
  margin-top: 20rpx;
}
.reg-empty {
  font-size: 25rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.mine-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.mine-title {
  font-size: 27rpx;
  font-weight: 600;
}
.mine-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}
.mine-empty {
  font-size: 25rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 8rpx;
}
.mine-btn {
  margin-top: 20rpx;
}

.merchant-intro {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 20rpx;
}
.merchant-note {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 16rpx 0;
}

.my-foot {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 12rpx;
}
