<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 短字段统一行式（标签左、值右），字段顺序与管理端表单一致 -->
    <view class="card form-list">
      <view class="frow">
        <text class="frow-label">标题</text>
        <input class="frow-input" placeholder="如：门窗团购（断桥铝）" value="{{title}}" data-field="title" bind:input="onInput" />
      </view>

      <!-- 品类带意向人数，是选择依据，所以用整块 chips 而不是行式输入 -->
      <view class="fblock">
        <view class="q-title">品类<text class="q-note">数字是已登记想团这个品类的人数</text></view>
        <view class="chips">
          <view
            wx:for="{{categories}}"
            wx:key="*this"
            class="chip {{category === item ? 'chip-on' : ''}}"
            data-value="{{item}}"
            bind:tap="pickCategory"
          >{{item}}<text class="chip-count" wx:if="{{interestCount[item]}}"> · {{interestCount[item]}}人</text></view>
        </view>
        <input class="fin fin-top" placeholder="或自定义品类，如 智能家居" value="{{customCategory}}" data-field="customCategory" bind:input="onInput" />
      </view>

      <view class="frow">
        <text class="frow-label">阶梯优惠</text>
        <input class="frow-input" placeholder="如：满 20 人赠全屋水电升级" value="{{perk}}" data-field="perk" bind:input="onInput" />
      </view>

      <view class="frow">
        <text class="frow-label">目标人数<text class="q-note">达到后去和商家谈价</text></text>
        <input class="frow-input" type="number" placeholder="必填" value="{{targetCount}}" data-field="targetCount" bind:input="onInput" />
      </view>

      <!-- 状态流转：单选走 action-sheet，与管理端表单同一套交互 -->
      <view class="frow" wx:if="{{stateKeys.length}}" hover-class="frow-hover" bind:tap="chooseState">
        <view class="frow-main">
          <view class="row-title">状态</view>
          <view class="row-sub">还没谈价选「意向征集」先探人数，条件谈好了选「接龙中」</view>
        </view>
        <text class="frow-value">{{states[state]}}</text>
        <text class="frow-arrow">›</text>
      </view>
    </view>

    <view class="card">
      <view class="q-title">团长的话<text class="q-note">写给邻居看，透明是信任的来源</text></view>
      <textarea class="fin farea" auto-height placeholder="如：我自己家就用这家，条件对每家一样" value="{{pitch}}" data-field="pitch" bind:input="onInput" maxlength="1000" />
    </view>

    <view class="card">
      <view class="q-title">团购条件<text class="q-note">谈成后再填也可以</text></view>
      <view class="pair" wx:for="{{terms}}" wx:key="index">
        <input class="fin pair-a" placeholder="名目" value="{{item.label}}" data-list="terms" data-index="{{index}}" data-field="label" bind:input="onRowInput" />
        <input class="fin pair-b" placeholder="如 618 元/㎡" value="{{item.value}}" data-list="terms" data-index="{{index}}" data-field="value" bind:input="onRowInput" />
        <view class="pair-del" data-list="terms" data-index="{{index}}" bind:tap="removeRow">✕</view>
      </view>
      <view class="add-row" data-list="terms" bind:tap="addRow">＋ 添加一条</view>
    </view>

    <view class="card">
      <view class="q-title">买前必懂<text class="q-note">大白话解释术语，3~5 条</text></view>
      <view class="pair pair-col" wx:for="{{glossary}}" wx:key="index">
        <view class="pair-head">
          <input class="fin pair-a" placeholder="术语，如 断桥铝" value="{{item.term}}" data-list="glossary" data-index="{{index}}" data-field="term" bind:input="onRowInput" />
          <view class="pair-del" data-list="glossary" data-index="{{index}}" bind:tap="removeRow">✕</view>
        </view>
        <textarea class="fin farea" auto-height placeholder="大白话解释 + 对决策的影响" value="{{item.explain}}" data-list="glossary" data-index="{{index}}" data-field="explain" bind:input="onRowInput" maxlength="300" />
      </view>
      <view class="add-row" data-list="glossary" bind:tap="addRow">＋ 添加一条</view>
    </view>

    <view class="privacy">{{initiatorNote}}</view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" loading="{{submitting}}" bind:tap="submit">{{id ? '保存' : '提交审核'}}</t-button>
    </view>
  </page-status>
</view>
