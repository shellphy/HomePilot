<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 短字段统一行式（标签左、值右），字段顺序与管理端表单一致 -->
    <view class="card form-list">
      <view class="frow">
        <text class="frow-label">标题<text class="f-required">*</text></text>
        <input class="frow-input" placeholder="如：门窗团购（断桥铝）" value="{{title}}" maxlength="60" data-field="title" bind:input="onInput" />
      </view>

      <view class="frow">
        <text class="frow-label">品类<text class="f-required">*</text></text>
        <input class="frow-input" placeholder="如：装修公司、门窗" value="{{category}}" maxlength="30" data-field="category" bind:input="onInput" />
      </view>

      <view class="frow">
        <text class="frow-label">阶梯优惠</text>
        <input class="frow-input" placeholder="如：满 20 人赠全屋水电升级" value="{{perk}}" maxlength="100" data-field="perk" bind:input="onInput" />
      </view>

      <view class="frow">
        <text class="frow-label">目标人数<text class="f-required">*</text><text class="q-note">达到后去和商家谈价</text></text>
        <input class="frow-input" type="number" value="{{targetCount}}" placeholder="如 20" data-field="targetCount" bind:input="onInput" />
      </view>

      <!-- 方案型开关只在发起时可选：中途翻转会改变联系互通的隐私承诺 -->
      <view class="frow" wx:if="{{!id}}">
        <view class="frow-main">
          <view class="row-title">按户出方案</view>
          <view class="row-sub">中央空调、全屋定制这类选它：商家逐户沟通需求（如上门量房）、单独出方案报价，报名邻居的手机号从谈判阶段起与你互通</view>
        </view>
        <switch checked="{{needsSurvey}}" bind:change="onSurveyChange" color="#06ae56" />
      </view>
      <view class="frow" wx:elif="{{needsSurvey}}">
        <view class="frow-main">
          <view class="row-title">按户出方案</view>
          <view class="row-sub">发起时已选定，不可修改</view>
        </view>
        <text class="frow-value">已开启</text>
      </view>

      <!-- 状态流转不在编辑表单里：团长只能沿状态机推进一步，入口统一在详情页的「推进到下一站」 -->
    </view>

    <view class="card">
      <view class="q-title">团长的话<text class="q-note">写给邻居看，透明是信任的来源</text></view>
      <textarea class="fin farea" auto-height placeholder="如：我自己家就用这家，条件对每家一样" value="{{pitch}}" data-field="pitch" bind:input="onInput" maxlength="1000" />
    </view>

    <view class="card">
      <view class="q-title">团购条件<text class="q-note">谈成后再填也可以</text></view>
      <view class="pair" wx:for="{{terms}}" wx:key="index">
        <input class="fin pair-a" placeholder="名目" value="{{item.label}}" maxlength="30" data-list="terms" data-index="{{index}}" data-field="label" bind:input="onRowInput" />
        <input class="fin pair-b" placeholder="如 618 元/㎡" value="{{item.value}}" maxlength="100" data-list="terms" data-index="{{index}}" data-field="value" bind:input="onRowInput" />
        <view class="pair-del" data-list="terms" data-index="{{index}}" bind:tap="removeRow">✕</view>
      </view>
      <view class="add-row" data-list="terms" bind:tap="addRow">＋ 添加一条</view>
    </view>

    <view class="card">
      <view class="q-title">买前必懂<text class="q-note">大白话解释术语，3~5 条</text></view>
      <view class="pair pair-col" wx:for="{{glossary}}" wx:key="index">
        <view class="pair-head">
          <input class="fin pair-a" placeholder="术语，如 断桥铝" value="{{item.term}}" maxlength="30" data-list="glossary" data-index="{{index}}" data-field="term" bind:input="onRowInput" />
          <view class="pair-del" data-list="glossary" data-index="{{index}}" bind:tap="removeRow">✕</view>
        </view>
        <textarea class="fin farea" auto-height placeholder="大白话解释 + 对决策的影响" value="{{item.explain}}" data-list="glossary" data-index="{{index}}" data-field="explain" bind:input="onRowInput" maxlength="300" />
      </view>
      <view class="add-row" data-list="glossary" bind:tap="addRow">＋ 添加一条</view>
    </view>

    <view class="privacy">{{initiatorNote}}</view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit">{{id ? '保存' : '提交审核'}}</t-button>
    </view>
  </page-status>
</view>
