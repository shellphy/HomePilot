.step-bar {
  padding: 4rpx 8rpx 24rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
}

.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.nav-prev {
  flex: 1;
}
.nav-next {
  flex: 2;
}

.skip-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding-top: 20rpx;
}
