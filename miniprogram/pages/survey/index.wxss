.step-bar {
  padding: 4rpx 8rpx 24rpx;
}
.step-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.step-meter {
  height: 8rpx;
}
.step-intro {
  font-size: 23rpx;
  color: #9b978c;
  margin-top: 14rpx;
}

.q-title {
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}
.q-note {
  font-size: 22rpx;
  font-weight: 400;
  color: #9b978c;
  margin-left: 12rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  border: 1rpx solid #edece7;
  background: #f6f6f3;
  border-radius: 16rpx;
  padding: 16rpx 26rpx;
  font-size: 26rpx;
}
.chip-on {
  background: #e4f6ec;
  border-color: #06ae56;
  color: #067a3f;
  font-weight: 600;
}

.nav-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.nav-prev {
  flex: 1;
}
.nav-next {
  flex: 2;
}

.skip-note {
  text-align: center;
  font-size: 22rpx;
  color: #9b978c;
  padding-top: 20rpx;
}
