<view class="page-body has-footer">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="form-hint">成交公示是团购的最后一步：把最终谈成的条件、返点让利的去向摊开给全小区看。透明是下一个团的信任来源。</view>

    <!-- 逐人报价的团每人成交价不同：引导公示规则口径（折扣/返利/成交人数/人均区间） -->
    <view class="form-hint" wx:if="{{needsSurvey}}">这是逐人报价的团购，每人成交价不同：公示统一的规则（如折扣、返利、免费项）和成交人数、人均价区间，让邻居能对照自己的方案核验。</view>

    <view class="card">
      <view class="q-title">最终成交条件<text class="f-required">*</text><text class="q-note">{{needsSurvey ? '写规则与区间，如「统一 8.2 折」「成交 12 户」' : '已预填团购条件，请改成实际成交版'}}</text></view>
      <view class="row-item" wx:for="{{finalTerms}}" wx:key="index">
        <input class="fin row-label" value="{{item.label}}" data-index="{{index}}" data-key="label" bind:input="onRowInput" />
        <input class="fin row-value" value="{{item.value}}" data-index="{{index}}" data-key="value" bind:input="onRowInput" />
        <view class="row-del" data-index="{{index}}" bind:tap="removeTerm">✕</view>
      </view>
      <view class="row-add" bind:tap="addTerm">+ 添加一条</view>
    </view>

    <view class="card">
      <view class="q-title">成交说明<text class="q-note">返点让利怎么给的，写在这里</text></view>
      <textarea
        class="fin farea"
        auto-height
        value="{{finalNote}}"
        bind:input="onNoteInput"
        maxlength="1000"
      />
    </view>

    <view class="footer-bar">
      <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit">发布成交公示</t-button>
    </view>
  </page-status>
</view>
