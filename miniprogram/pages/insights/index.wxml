<view class="page-body tabbed">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 进行中的征集：参与率 + 头牌数据 + 参与按钮；有查看权限时才能点卡片看完整数据 -->
    <block wx:if="{{openCards.length}}">
      <view class="feed-head">正在征集</view>
      <view
        class="card fcard"
        hover-class="{{item.aggregatesVisible ? 'card-hover' : 'none'}}"
        wx:for="{{openCards}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-visible="{{item.aggregatesVisible}}"
        bind:tap="goDetail"
      >
        <view class="fcard-row">
          <view class="fcard-tag">征集中</view>
          <view class="fcard-title">{{item.title}}</view>
        </view>
        <view wx:if="{{item.body}}" class="fcard-pitch">{{item.body}}</view>
        <view wx:if="{{item.top}}" class="fcard-top"
          >「{{item.top.question}}」答得最多的是 {{item.top.label}}（{{item.top.count}} 人）</view
        >
        <view wx:if="{{item.hasParticipationRate}}" class="fcard-meter" aria-label="参与率 {{item.participationRate}}%">
          <view class="fcard-fill" style="width: {{item.participationRate}}%"></view>
        </view>
        <view class="fcard-foot">
          <text wx:if="{{item.hasParticipationRate}}"
            ><text class="fcard-num">{{item.registered}} / {{item.totalResidents}}</text> 人参与 · 参与率
            {{item.participationRate}}%</text
          >
          <text wx:else><text class="fcard-num">{{item.registered}}</text> 人已参与</text>
          <text wx:if="{{item.aggregatesVisible}}" class="fcard-cta">看完整数据 ›</text>
        </view>
        <!-- tap 必须绑在 t-button 本身：TDesign 内部原生 button 用 catch:tap 截断后
             以 triggerEvent 重发（不冒泡），绑在外层 view 上收不到；
             重发的 tap 也不会冒泡到卡片，因此不会误触 goDetail。
             宽度用 style 直传：TDesign 模板会把 style 显式转发到内部按钮根节点，
             外部 class 在 virtualHost 渲染下不一定作用到按钮盒子 -->
        <view class="fcard-btn">
          <t-button
            theme="primary"
            block
            size="large"
            style="width: 100%"
            data-id="{{item.id}}"
            data-answered="{{item.myAnswered}}"
            bind:tap="goRegistration"
            >{{item.myAnswered ? '查看我的问卷' : '参与问卷'}}</t-button
          >
        </view>
      </view>
    </block>

    <!-- 已结束的往期：一行一期，点进看详情 -->
    <block wx:if="{{pastItems.length}}">
      <view class="feed-head">往期数据</view>
      <view class="card census-list">
        <view
          class="crow"
          hover-class="{{item.aggregatesVisible ? 'crow-hover' : 'none'}}"
          wx:for="{{pastItems}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-visible="{{item.aggregatesVisible}}"
          bind:tap="goDetail"
        >
          <text class="crow-title">{{item.title}}</text>
          <view class="crow-right">
            <text class="crow-note">{{item.note}}</text>
            <text wx:if="{{item.aggregatesVisible}}" class="crow-arrow">›</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 全局空态：一份征集都没有时给个交代 -->
    <view wx:if="{{!openCards.length && !pastItems.length}}" class="hint">小区还没有征集。需要摸底的事，管理员可以发起一份。</view>
  </page-status>
</view>
