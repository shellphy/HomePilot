.feed-head {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 12rpx 8rpx 16rpx;
}

/* 进行中的征集大卡 */
.fcard-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.fcard-tag {
  font-size: 21rpx;
  font-weight: 600;
  color: var(--brand-deep);
  background: var(--brand-bg);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}
.fcard-title {
  flex: 1;
  font-size: 29rpx;
  font-weight: 600;
}
.fcard-pitch {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.fcard-top {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}
.fcard-meter {
  height: 16rpx;
  border-radius: 8rpx;
  background: var(--bg-page);
  overflow: hidden;
  margin-top: 20rpx;
}
.fcard-fill {
  height: 100%;
  background: var(--brand);
  border-radius: 0 8rpx 8rpx 0;
}
.fcard-foot {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 14rpx;
}
.fcard-num {
  font-weight: 700;
  color: var(--text-primary);
}
.fcard-cta {
  color: var(--brand-deep);
  font-weight: 600;
}
.fcard-btn {
  margin-top: 20rpx;
}

/* 往期征集列表 */
.census-list {
  padding-top: 0;
  padding-bottom: 0;
}
.crow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  height: 112rpx;
  border-bottom: 1rpx solid var(--line);
}
.crow:last-child {
  border-bottom: none;
}
.crow-hover {
  opacity: 0.55;
}
.crow-title {
  font-size: 28rpx;
  color: var(--text-primary);
  flex-shrink: 0;
}
.crow-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}
.crow-note {
  font-size: 24rpx;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.crow-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: var(--line-dark);
  flex-shrink: 0;
}
