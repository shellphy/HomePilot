<view class="page-body tabbed">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 小区门户头 -->
    <view class="portal">
      <view class="portal-name">{{community.app_name}}</view>
      <view class="portal-sub">{{community.slogan}} · {{community.sub_slogan}}</view>
      <view class="portal-stats">
        <view class="pstat" bind:tap="goInsights">
          <view class="pstat-num">{{residents}}<text class="pstat-unit"> 位</text></view>
          <view class="pstat-label">邻居在这里 · 小区数据 ›</view>
        </view>
        <view
          class="portal-btn"
          hover-class="portal-btn-hover"
          wx:if="{{initiatableTypes.length}}"
          bind:tap="goCreate"
        >我来张罗</view>
      </view>
    </view>

    <!-- 公告 -->
    <block wx:if="{{notices.length}}">
      <view class="feed-head">小区公告</view>
      <notice-card wx:for="{{notices}}" wx:key="id" matter="{{item}}" />
    </block>

    <!-- 正在张罗的事 -->
    <view class="feed-head">大家正在张罗的事</view>
    <block wx:for="{{doings}}" wx:key="id">
      <groupbuy-card wx:if="{{item.type === 'groupbuy'}}" matter="{{item}}" />
      <census-card wx:elif="{{item.type === 'census'}}" matter="{{item}}" />
      <matter-card wx:else matter="{{item}}" />
    </block>
    <view wx:if="{{!doings.length}}" class="hint">还没有人牵头张罗。第一个张罗的人，就是这件事的牵头人。</view>
  </page-status>
</view>
