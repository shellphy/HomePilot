<view class="page-body tabbed">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 小区门户头 -->
    <view class="portal">
      <view class="portal-name">{{community.name}}</view>
      <view class="portal-sub" wx:if="{{community.slogan || community.sub_slogan}}">{{community.slogan}}{{community.slogan && community.sub_slogan ? ' · ' : ''}}{{community.sub_slogan}}</view>
      <view class="portal-stats">
        <!-- 只做氛围数字 -->
        <view class="pstat">
          <view class="pstat-num">{{residents}}<text class="pstat-unit"> 位</text></view>
          <view class="pstat-label">邻居在这里</view>
        </view>
        <view
          class="portal-btn"
          hover-class="portal-btn-hover"
          wx:if="{{initiatableTypes.length || merchantUnlisted}}"
          bind:tap="goCreate"
        >我来张罗</view>
      </view>
    </view>

    <!-- 待我处理：首页只 peek 最高优先级的几项，其余去「我的」看全量 -->
    <todo-list todos="{{todos}}" limit="{{3}}" />

    <!-- 已核验商家名录入口（有核验商家才出现） -->
    <view wx:if="{{listedParties}}" class="card prow" hover-class="row-hover" bind:tap="goParties">
      <text class="prow-title">已核验商家名录</text>
      <text class="prow-note">{{listedParties}} 家 ›</text>
    </view>

    <!-- 正在征集指引卡：征集聚合在 insights 子页，这里只放一个发现入口 -->
    <view wx:if="{{openCensusCount}}" class="card prow" hover-class="row-hover" bind:tap="goCensus">
      <text class="prow-title">正在征集</text>
      <text class="prow-note">{{openCensusCount}} 项 ›</text>
    </view>

    <!-- 公告 -->
    <block wx:if="{{notices.length}}">
      <view class="feed-head">小区公告</view>
      <notice-card wx:for="{{notices}}" wx:key="id" matter="{{item}}" />
    </block>

    <!-- 正在张罗的事 -->
    <view class="feed-head">大家正在张罗的事</view>
    <!-- 类型筛选：进行中的事有 ≥2 种类型时才露出 -->
    <view wx:if="{{feedTypes.length > 1}}" class="chips filter-chips">
      <view class="chip {{typeFilter === '' ? 'chip-on' : ''}}" data-type="" bind:tap="pickType">全部</view>
      <view
        class="chip {{typeFilter === item.key ? 'chip-on' : ''}}"
        wx:for="{{feedTypes}}"
        wx:key="key"
        data-type="{{item.key}}"
        bind:tap="pickType"
      >{{item.label}}</view>
    </view>
    <matter-card wx:for="{{visibleDoings}}" wx:key="id" matter="{{item}}" />
    <!-- 筛选后本类型没有，但整体有事：轻提示，不占号召位 -->
    <view wx:if="{{doings.length && !visibleDoings.length}}" class="hint">这个类型暂时没有正在张罗的事</view>
    <!-- 空态：号召和行动放在同一处，别让人读完还得回头找顶部入口 -->
    <view wx:if="{{!doings.length}}" class="hint">
      {{finished.length ? '进行中的事都收尾了。下一件事，等你来张罗。' : '还没有人牵头张罗。第一个张罗的人，就是这件事的牵头人。'}}
      <view class="empty-cta" wx:if="{{initiatableTypes.length || merchantUnlisted}}">
        <t-button theme="primary" size="medium" bind:tap="goCreate">我来张罗{{finished.length ? '一件事' : '第一件事'}}</t-button>
      </view>
    </view>

    <!-- 已收尾的事：压成单行收在最底部，不跟进行中的抢版面（对齐数据页「往期数据」的行式） -->
    <block wx:if="{{finished.length}}">
      <view class="feed-head">已经收尾的事</view>
      <view class="card finished-list">
        <view
          class="drow"
          hover-class="row-hover"
          wx:for="{{finished}}"
          wx:key="id"
          data-id="{{item.id}}"
          bind:tap="goFinished"
        >
          <text class="drow-title">{{item.title}}</text>
          <view class="drow-right">
            <text class="drow-note">{{item.note}}</text>
            <text class="drow-arrow">›</text>
          </view>
        </view>
      </view>
    </block>
  </page-status>
</view>
