<view class="page-body tabbed">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <!-- 市集门户头 -->
    <view class="portal">
      <view class="portal-name">邻里市集</view>
      <view class="portal-sub">团购拼一波，闲置传一手</view>
      <view class="portal-stats">
        <view class="pstat">
          <view class="pstat-num">{{doings.length}}<text class="pstat-unit"> 件</text></view>
          <view class="pstat-label">正在市集</view>
        </view>
        <view
          class="portal-btn"
          hover-class="portal-btn-hover"
          wx:if="{{initiatableTypes.length || merchantUnlisted}}"
          bind:tap="goCreate"
        >我要发布</view>
      </view>
    </view>

    <!-- 类型筛选：在售里有 ≥2 种类型（团购/闲置）时才露出 -->
    <view wx:if="{{feedTypes.length > 1}}" class="chips filter-chips">
      <view class="chip {{typeFilter === '' ? 'chip-on' : ''}}" data-type="" bind:tap="pickType">全部</view>
      <view
        class="chip {{typeFilter === item.key ? 'chip-on' : ''}}"
        wx:for="{{feedTypes}}"
        wx:key="key"
        data-type="{{item.key}}"
        bind:tap="pickType"
      >{{item.label}}</view>
    </view>

    <!-- 团购用 groupbuy-card，二手闲置用通用 matter-card -->
    <block wx:for="{{visibleDoings}}" wx:key="id">
      <groupbuy-card wx:if="{{item.type === 'groupbuy'}}" matter="{{item}}" />
      <matter-card wx:else matter="{{item}}" />
    </block>

    <!-- 筛选后本类型没有，但整体有货：轻提示，不占号召位 -->
    <view wx:if="{{doings.length && !visibleDoings.length}}" class="hint">这个类型暂时没有在市集里</view>
    <!-- 空态：号召与行动同处 -->
    <view wx:if="{{!doings.length}}" class="hint">
      市集还空着。第一个摆摊的，就是你。
      <view class="empty-cta" wx:if="{{initiatableTypes.length || merchantUnlisted}}">
        <t-button theme="primary" size="medium" bind:tap="goCreate">我要发布</t-button>
      </view>
    </view>

    <!-- 已收场的：压成单行收在最底部 -->
    <block wx:if="{{finished.length}}">
      <view class="feed-head">已经收场的</view>
      <view class="card finished-list">
        <view
          class="drow"
          hover-class="row-hover"
          wx:for="{{finished}}"
          wx:key="id"
          data-id="{{item.id}}"
          bind:tap="goFinished"
        >
          <text class="drow-title">{{item.title}}</text>
          <view class="drow-right">
            <text class="drow-note">{{item.note}}</text>
            <text class="drow-arrow">›</text>
          </view>
        </view>
      </view>
    </block>
  </page-status>
</view>
