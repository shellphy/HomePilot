/* 表单项之间留出呼吸感：上一项输入框与下一项标题不再贴在一起 */
.q-title-gap {
  margin-top: 28rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.row:last-child {
  border-bottom: none;
}
.row-hover {
  opacity: 0.7;
}
.row-main {
  flex: 1;
  min-width: 0;
}
.row-title {
  font-size: 27rpx;
  font-weight: 600;
}
.row-sub {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.row-arrow {
  font-size: 36rpx;
  color: var(--line-dark);
  flex-shrink: 0;
}
