.form-hint {
  font-size: 24rpx;
  color: #6e6b63;
  padding: 0 8rpx 20rpx;
}

.q-title {
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}
.q-note {
  font-size: 22rpx;
  font-weight: 400;
  color: #9b978c;
  margin-left: 12rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  border: 1rpx solid #edece7;
  background: #f6f6f3;
  border-radius: 16rpx;
  padding: 16rpx 26rpx;
  font-size: 26rpx;
}
.chip-on {
  background: #e4f6ec;
  border-color: #06ae56;
  color: #067a3f;
  font-weight: 600;
}

.fin {
  background: #f6f6f3;
  border: 1rpx solid #edece7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

.f-label {
  font-size: 24rpx;
  color: #6e6b63;
  margin: 20rpx 0 12rpx;
}
.f-label:first-of-type {
  margin-top: 0;
}
.f-required {
  font-size: 20rpx;
  color: #b4501e;
  margin-left: 8rpx;
}

.privacy {
  font-size: 22rpx;
  color: #9b978c;
  line-height: 1.7;
  padding: 4rpx 8rpx 20rpx;
}
