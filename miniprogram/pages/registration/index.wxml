<view class="page-body" wx:if="{{loaded}}">
  <view class="form-hint">约 2 分钟 · 明细仅管理员可见，对外只展示汇总统计</view>

  <view class="card">
    <view class="q-title">1 / 4 · 你家是哪个户型？</view>
    <view class="chips">
      <view
        wx:for="{{layouts}}"
        wx:key="*this"
        class="chip {{layout === item ? 'chip-on' : ''}}"
        data-value="{{item}}"
        bindtap="pickLayout"
      >{{item}}</view>
    </view>
  </view>

  <view class="card">
    <view class="q-title">2 / 4 · 打算怎么装？</view>
    <view class="chips">
      <view
        wx:for="{{decorationModes}}"
        wx:key="*this"
        class="chip {{decorationMode === item ? 'chip-on' : ''}}"
        data-value="{{item}}"
        bindtap="pickMode"
      >{{item}}</view>
    </view>
  </view>

  <view class="card">
    <view class="q-title">3 / 4 · 对哪些团购感兴趣？<text class="q-note">可多选</text></view>
    <view class="chips">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="chip {{interestOn[item] ? 'chip-on' : ''}}"
        data-value="{{item}}"
        bindtap="toggleInterest"
      >{{item}}</view>
    </view>
  </view>

  <view class="card">
    <view class="q-title">4 / 4 · 联系方式</view>
    <view class="f-label">楼栋号<text class="f-required">必填</text><text class="q-note">只填楼栋，不用填房号</text></view>
    <input class="fin" placeholder="如：3栋" value="{{unitLabel}}" data-field="unitLabel" bindinput="onInput" />
    <view class="f-label">微信号<text class="f-required">必填</text><text class="q-note">团购有进展时联系你</text></view>
    <input class="fin" placeholder="微信 → 我 → 帐号里能看到" value="{{wechatId}}" data-field="wechatId" bindinput="onInput" />
    <view class="f-label">手机号<text class="q-note">选填，介意可不填</text></view>
    <input class="fin" type="number" placeholder="仅管理员可见" value="{{phone}}" data-field="phone" bindinput="onInput" />
  </view>

  <view class="privacy">提交即同意：楼栋与昵称用于接龙展示；微信号和手机号仅管理员用于团购联络，不提供给任何商家。</view>
  <t-button theme="primary" block size="large" loading="{{submitting}}" bind:tap="submit">提交登记</t-button>
</view>
