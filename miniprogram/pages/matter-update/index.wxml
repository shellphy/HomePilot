<view class="page-body has-footer">
  <view class="form-hint">进度会显示在事项详情的时间线里，全小区都能看到。常更新，参与的邻居才放心。</view>

  <view class="card">
    <view class="q-title">日期</view>
    <picker mode="date" value="{{date}}" end="{{today}}" bind:change="onDateChange">
      <!-- 带箭头，别让日期长得像个点不动的输入框 -->
      <view class="fin picker-line">
        <text>{{date}}</text>
        <text class="picker-arrow">›</text>
      </view>
    </picker>
  </view>

  <view class="card">
    <view class="q-title">进度内容</view>
    <textarea class="fin farea" value="{{content}}" bind:input="onInput" maxlength="500" />
  </view>

  <view class="card">
    <view class="q-title">现场照片<text class="q-note">最多 9 张，拍了就传</text></view>
    <view class="shots">
      <view class="shot-wrap" wx:for="{{images}}" wx:key="*this">
        <image class="shot" src="{{item}}" mode="aspectFill" data-url="{{item}}" bind:tap="previewImage" />
        <view class="shot-del" data-index="{{index}}" catch:tap="removeImage">✕</view>
      </view>
      <view class="shot-add" bind:tap="chooseImages">{{uploading ? '上传中…' : '+'}}</view>
    </view>
  </view>

  <view class="footer-bar">
    <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="submit">发布进度</t-button>
  </view>
</view>
