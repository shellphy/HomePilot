/* 日期选择行：右侧箭头提示可点 */
.picker-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  line-height: 1;
  color: var(--line-dark);
}

.shots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.shot-wrap {
  position: relative;
}
.shot {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: var(--line);
}
.shot-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.shot-add {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  border: 2rpx dashed var(--line-dark);
  color: var(--text-muted);
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
