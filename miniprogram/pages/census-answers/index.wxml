<view class="page-body">
  <page-status loaded="{{loaded}}" error="{{loadError}}" bind:retry="reload">
    <view class="card registration-summary">
      <view class="registration-summary-head">
        <view>
          <view class="registration-title">我的问卷</view>
          <view class="registration-count">已回答 {{answeredCount}} 题</view>
        </view>
      </view>
      <view class="questionnaire-actions">
        <view class="questionnaire-action" wx:if="{{censusState === 'open'}}" bind:tap="goEdit">修改问卷</view>
        <view class="questionnaire-action" bind:tap="goStats">整体数据</view>
        <view class="questionnaire-action {{reportStatus === 'pending' ? 'questionnaire-action-busy' : ''}}" bind:tap="onSummaryTap">
          <text wx:if="{{reportStatus === 'pending'}}" class="action-spinner"></text>
          <text>{{reportStatus === 'pending' ? 'AI 总结中' : (reportStatus === 'completed' ? '查看 AI 总结' : 'AI 总结')}}</text>
        </view>
      </view>
    </view>

    <!-- 授权发起者查看：署名发起方才出现，看着自己的答案冷静决定，默认关、随时可改 -->
    <view wx:if="{{initiatorParty}}" class="card consent-card">
      <view class="consent-row">
        <view class="consent-title">让「{{initiatorParty.label}} · {{initiatorParty.name}}」看到我的问卷</view>
        <switch checked="{{visibleToInitiator}}" color="#06ae56" bindchange="toggleConsent" />
      </view>
      <view class="consent-sub">开启后 TA 能看到你的联系方式和每道题的回答；不开启只计入匿名统计。</view>
    </view>

    <view class="content-heading">
      <view class="content-heading-title">我的回答</view>
    </view>

    <view class="card registration-module {{item.expanded ? 'registration-module-open' : ''}}" wx:for="{{answerModules}}" wx:key="key">
      <view class="registration-module-head" data-index="{{index}}" bind:tap="toggleModule">
        <view class="registration-module-title">{{item.title}}</view>
        <view class="registration-module-meta">
          <view class="registration-module-count">{{item.questions.length}} 题</view>
          <text class="registration-arrow {{item.expanded ? 'registration-arrow-open' : ''}}">›</text>
        </view>
      </view>
      <view wx:if="{{item.expanded}}" class="registration-answers">
        <view class="registration-answer" wx:for="{{item.questions}}" wx:for-item="question" wx:for-index="questionIndex" wx:key="key">
          <view class="registration-question-row">
            <text class="registration-question-index">{{questionIndex + 1}}</text>
            <view class="registration-question">{{question.text}}</view>
          </view>
          <view class="registration-value">{{question.answer}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!answerModules.length}}" class="hint">还没有已提交的回答</view>
  </page-status>
</view>
