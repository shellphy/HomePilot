<view class="card">
  <view class="head-row">
    <view class="pill {{pillClass}}">{{matter.state_label}}</view>
    <view class="head-count">
      <text class="head-num">{{matter.join_count}}</text>
      <text wx:if="{{matter.target_count}}"> / {{matter.target_count}} 人</text>
      <text wx:else> 人</text>
    </view>
  </view>
  <view wx:if="{{matter.state === 'open' && matter.target_count}}" class="meter head-meter">
    <view class="meter-fill" style="width: {{percent}}%"></view>
  </view>
  <view wx:if="{{matter.perk}}" class="head-perk">🎁 {{matter.perk}}</view>
</view>

<view class="card" wx:if="{{matter.pitch}}">
  <view class="kicker">发起人的话</view>
  <view class="pitch">“{{matter.pitch}}”</view>
  <view class="pitch-sign" wx:if="{{matter.initiator_name}}">—— {{matter.initiator_name}} · {{matter.initiator_party ? '已认证' + matter.initiator_party.label + ' · 本团发起人' : '本团发起人'}}</view>
</view>

<view class="card" wx:if="{{matter.glossary.length}}">
  <view class="kicker">买前必懂 · 看完再决定</view>
  <view class="gl" wx:for="{{matter.glossary}}" wx:key="term">
    <view class="gl-term">{{item.term}}</view>
    <view class="gl-explain">{{item.explain}}</view>
  </view>
</view>

<view class="card" wx:if="{{matter.terms.length}}">
  <view class="kicker">团购条件</view>
  <view class="term-row" wx:for="{{matter.terms}}" wx:key="label">
    <text class="term-label">{{item.label}}</text>
    <text class="term-value">{{item.value}}</text>
  </view>
</view>

<view class="card deal-card" wx:if="{{matter.final_terms.length}}">
  <view class="kicker">成交公示 · 最终条件</view>
  <view class="term-row" wx:for="{{matter.final_terms}}" wx:key="label">
    <text class="term-label">{{item.label}}</text>
    <text class="term-value">{{item.value}}</text>
  </view>
  <view class="deal-note" wx:if="{{matter.final_note}}">{{matter.final_note}}</view>
</view>

<view class="card pending-tip" wx:if="{{!matter.is_approved}}">
  <block wx:if="{{matter.reject_reason}}">❌ 已被驳回：{{matter.reject_reason}}（修改后保存即重新提交审核）</block>
  <block wx:else>⏳ 待管理员审核，通过后才会出现在小区页里（只有你自己能看到这个页面）</block>
</view>

<!-- 成团后的联系互通：参团者见团长 -->
<view class="card deal-card" wx:if="{{initiatorContact}}">
  <view class="kicker">联系团长 · 建群与对接</view>
  <view class="term-row">
    <text class="term-label">{{initiatorContact.name}}</text>
    <text class="term-value" data-phone="{{initiatorContact.phone}}" bind:tap="copyPhone">{{initiatorContact.phone}} 复制</text>
  </view>
</view>

<!-- 成团后的联系互通：团长见同意共享的参团者 -->
<view class="card deal-card" wx:if="{{isInitiator && contacts.length}}">
  <view class="kicker">参团联系名单（{{contacts.length}}）· 仅你可见，用于建群对接</view>
  <view class="term-row" wx:for="{{contacts}}" wx:key="phone">
    <text class="term-label">{{item.name}}</text>
    <text class="term-value" data-phone="{{item.phone}}" bind:tap="copyPhone">{{item.phone}} 复制</text>
  </view>
</view>

<view class="card leader-ops" wx:if="{{isInitiator}}">
  <view class="kicker">发起人操作（这个团购由你负责）</view>
  <view class="leader-btns">
    <t-button theme="light" size="medium" bind:tap="goProgress">发布进度</t-button>
    <t-button theme="light" size="medium" bind:tap="flipState">流转状态</t-button>
    <t-button theme="light" size="medium" bind:tap="goEdit">编辑团购</t-button>
    <t-button wx:if="{{matter.state === 'done'}}" theme="primary" size="medium" bind:tap="goDeal">成交公示</t-button>
  </view>
</view>

<view class="card" wx:if="{{matter.updates.length}}">
  <view class="kicker">进度更新</view>
  <view class="tline" wx:for="{{matter.updates}}" wx:key="index">
    <view class="tline-dot {{index === 0 ? 'tline-dot-latest' : ''}}"></view>
    <view class="tline-main">
      <view class="tline-date">{{item.happened_on}}{{item.author ? ' · ' + item.author + '（官方回应）' : ''}}</view>
      <view class="tline-content">{{item.content}}</view>
      <view class="tline-shots" wx:if="{{item.images.length}}">
        <image
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          class="tline-shot"
          src="{{img}}"
          mode="aspectFill"
          data-urls="{{item.images}}"
          data-current="{{img}}"
          bind:tap="previewImage"
        />
      </view>
    </view>
  </view>
</view>

<view class="card" wx:if="{{matter.roster.length}}">
  <view class="kicker">报名接龙 · 楼栋 + 昵称对外可见</view>
  <view class="roster-row" wx:for="{{matter.roster}}" wx:key="index">
    <text class="roster-idx">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
    <text>{{item}}</text>
  </view>
</view>

<view class="card" wx:if="{{matter.review_open && (reviews.length || joined)}}">
  <view class="kicker">参团邻居的评价{{reviews.length ? '（' + reviews.length + '）' : ''}}</view>

  <block wx:if="{{joined}}">
    <view class="review-form">
      <view class="review-form-title">{{myReview ? '我的评价（可修改）' : '这单结束了，给它打个分吧'}}</view>
      <t-rate value="{{reviewRating}}" size="44rpx" bind:change="onRateChange" />
      <textarea
        class="fin review-input"
        auto-height
        placeholder="一句话真实感受：价格、手艺、售后…（后来装修的邻居就靠它了）"
        value="{{reviewContent}}"
        bind:input="onReviewInput"
        maxlength="500"
      />
      <t-button theme="light" size="medium" block loading="{{submittingReview}}" bind:tap="submitReview">
        {{myReview ? '更新评价' : '发布评价'}}
      </t-button>
    </view>
  </block>

  <view class="review-row" wx:for="{{reviews}}" wx:key="index">
    <view class="review-head">
      <text class="review-name">{{item.reviewer_name}}</text>
      <text class="review-stars">{{item.stars}}</text>
    </view>
    <view class="review-content" wx:if="{{item.content}}">{{item.content}}</view>
    <view class="review-date">{{item.reviewed_on}}</view>
  </view>
</view>

<view class="cta-dock" wx:if="{{matter.join_open && !isParty}}">
  <view class="cta-share" wx:if="{{!joined}}">
    <text class="cta-share-text">成团后与团长互通手机号（仅双方可见）</text>
    <switch checked="{{shareContact}}" bind:change="onShareContactChange" color="#06ae56" />
  </view>
  <t-button
    theme="{{joined ? 'light' : 'primary'}}"
    block
    size="large"
    loading="{{submitting}}"
    bind:tap="toggleJoin"
  >{{joined ? '已报名 ✓（点击取消）' : (matter.state === 'seeking' ? '我感兴趣，登记意向' : '报名接龙')}}</t-button>
</view>
