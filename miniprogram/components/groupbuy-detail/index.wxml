<view class="card">
  <view class="head-row">
    <view class="pill {{pillClass}}">{{matter.state_label}}</view>
    <!-- 量词跟着阶段走，与列表卡片一致：意向期是「感兴趣」，接龙后按「已确认参团」口径 -->
    <view class="head-count">
      <text class="head-num">{{headCount}}</text>
      <text wx:if="{{matter.target_count}}"> / {{matter.target_count}} 人{{headNoun}}</text>
      <text wx:else> 人{{headNoun}}</text>
    </view>
  </view>
  <view wx:if="{{matter.state === 'open' && matter.target_count}}" class="meter head-meter">
    <view class="meter-fill" style="width: {{percent}}%"></view>
  </view>
  <!-- 两段表态：接龙中还挂着的意向，等本人回来确认才计入成团人数 -->
  <view wx:if="{{matter.state === 'open' && intentCount}}" class="head-intent"
    >另有 {{intentCount}} 人登记过意向，确认参团后才计入人数</view
  >
  <view wx:if="{{matter.needs_survey}}" class="head-survey"
    >逐人报价的团购：报名后商家单独和你沟通需求，你的方案和报价单独谈</view
  >
  <view wx:if="{{matter.perk}}" class="head-perk">{{matter.perk}}</view>
</view>

<view class="card" wx:if="{{matter.starts_on || matter.location || matter.registration_deadline_on}}">
  <view class="kicker">时间与地点</view>
  <view class="term-row" wx:if="{{matter.starts_on}}"><text class="term-label">开始</text><text class="term-value">{{matter.starts_on}}</text></view>
  <view class="term-row" wx:if="{{matter.registration_deadline_on}}"><text class="term-label">报名截止</text><text class="term-value">{{matter.registration_deadline_on}}{{matter.registration_closed ? '（已截止）' : ''}}</text></view>
  <view class="term-row" wx:if="{{matter.location}}"><text class="term-label">地点</text><text class="term-value">{{matter.location}}</text></view>
</view>

<view class="card" wx:if="{{matter.pitch}}">
  <view class="kicker">发起人的话</view>
  <view class="pitch"
    >“<text
      wx:for="{{pitchSegments}}"
      wx:for-item="seg"
      wx:key="index"
      class="{{seg.term ? 'term-hit' : ''}}"
      data-term="{{seg.term}}"
      bind:tap="showGlossary"
      >{{seg.text}}</text
    >”</view
  >
  <view class="pitch-sign" wx:if="{{matter.initiator_name}}"
    >—— {{matter.initiator_name}} · {{matter.initiator_party ? '已认证' + matter.initiator_party.label + ' · 本团发起人'
    : '本团发起人'}}</view
  >
</view>

<view class="card" wx:if="{{matter.glossary.length}}">
  <view class="kicker">买前必懂 · 看完再决定</view>
  <view class="gl" wx:for="{{matter.glossary}}" wx:key="term">
    <view class="gl-term">{{item.term}}</view>
    <view class="gl-explain">{{item.explain}}</view>
  </view>
</view>

<view class="card" wx:if="{{termRows.length}}">
  <view class="kicker">团购条件</view>
  <view class="term-row" wx:for="{{termRows}}" wx:key="label">
    <text class="term-label">{{item.label}}</text>
    <view class="term-value">
      <text
        wx:for="{{item.segments}}"
        wx:for-item="seg"
        wx:key="index"
        class="{{seg.term ? 'term-hit' : ''}}"
        data-term="{{seg.term}}"
        bind:tap="showGlossary"
        >{{seg.text}}</text
      >
    </view>
  </view>
</view>

<view class="card deal-card" wx:if="{{finalRows.length}}">
  <view class="kicker">成交公示 · 最终条件</view>
  <view class="term-row" wx:for="{{finalRows}}" wx:key="label">
    <text class="term-label">{{item.label}}</text>
    <view class="term-value">
      <text
        wx:for="{{item.segments}}"
        wx:for-item="seg"
        wx:key="index"
        class="{{seg.term ? 'term-hit' : ''}}"
        data-term="{{seg.term}}"
        bind:tap="showGlossary"
        >{{seg.text}}</text
      >
    </view>
  </view>
  <view class="deal-note" wx:if="{{matter.final_note}}">{{matter.final_note}}</view>
</view>

<!-- 驳回是「需要你处理」的负面结果，用红系；排队等待保持橙色中性 -->
<view
  class="card pending-tip {{matter.review_status === 'rejected' ? 'pending-tip-reject' : ''}}"
  wx:if="{{matter.review_status !== 'approved'}}"
>
  <block wx:if="{{matter.review_status === 'rejected'}}"
    >已被驳回：{{matter.reject_reason}}（修改后保存即重新提交审核）</block
  >
  <block wx:else>待审核，通过后就会出现在小区页里（只有你自己能看到这个页面）</block>
</view>

<!-- 联系互通阶段（标品团成团后；方案型团从谈判中开始）：参团者见团长 -->
<view class="card deal-card" wx:if="{{initiatorContact}}">
  <view class="kicker"
    >联系团长 · {{matter.needs_survey && matter.state !== 'done' ? '沟通需求、谈方案' : '建群与对接'}}</view
  >
  <view class="term-row">
    <text class="term-label">{{initiatorContact.name}}</text>
    <text class="term-value" data-phone="{{initiatorContact.phone}}" bind:tap="onPhoneTap"
      >{{initiatorContact.phone}} 拨打/复制</text
    >
  </view>
</view>

<!-- 互通阶段没共享联系方式的参团者：解释互通是双向对等的，给补开入口 -->
<view class="card deal-card" wx:if="{{matter.contacts_open && joined && !isInitiator && !myShareContact}}">
  <view class="kicker"
    >联系团长 · {{matter.needs_survey && matter.state !== 'done' ? '沟通需求、谈方案' : '建群与对接'}}</view
  >
  <view class="share-note">你报名时没有开启联系方式共享，你和团长现在互相看不到对方电话。</view>
  <t-button theme="light" size="medium" block style="width: 100%" bind:tap="enableShare">开启共享，与团长互通</t-button>
</view>

<!-- 联系互通阶段：团长见同意共享的参团者 -->
<view class="card deal-card" wx:if="{{isInitiator && contactRoster.length}}">
  <view class="kicker"
    >参与管理（{{contactRoster.length}}）· 仅你可见</view
  >
  <input class="fin" placeholder="搜索姓名、手机号或备注" value="{{rosterKeyword}}" bind:input="onRosterSearch" />
  <view class="term-row" wx:for="{{filteredRoster}}" wx:key="stance_id" data-index="{{index}}" bind:tap="editParticipant">
    <view>
      <view class="term-label">{{item.name}} · {{item.contact_status === 'contacted' ? '已联系' : '待联系'}}</view>
      <view class="share-note">{{item.leader_note || (item.share_contact ? '尚无备注' : '未同意共享手机号')}}</view>
    </view>
    <text class="term-value">{{item.phone || '无可用手机号'}} ›</text>
  </view>
</view>

<view class="card leader-ops" wx:if="{{isInitiator}}">
  <view class="kicker">发起人操作（这个团购由你负责）</view>
  <view class="leader-btns">
    <!-- 主操作单独占一整行做视觉锚点：成团后是成交公示，其余时候是发进度 -->
    <t-button
      wx:if="{{matter.state === 'done'}}"
      class="leader-btn-primary"
      theme="primary"
      size="medium"
      block
      style="width: 100%"
      bind:tap="goDeal"
      >成交公示</t-button
    >
    <t-button
      wx:else
      class="leader-btn-primary"
      theme="primary"
      size="medium"
      block
      style="width: 100%"
      bind:tap="goProgress"
      >发布进度</t-button
    >
    <!-- 次操作等宽两列对齐，落单的自动撑满整行 -->
    <view class="leader-btns-sub">
      <t-button
        wx:if="{{matter.state === 'done'}}"
        class="leader-btn"
        theme="light"
        size="medium"
        block
        bind:tap="goProgress"
        >发布进度</t-button
      >
      <t-button wx:if="{{nextState}}" class="leader-btn" theme="light" size="medium" block bind:tap="flipState"
        >推进到「{{nextState.label}}」</t-button
      >
      <t-button class="leader-btn" theme="light" size="medium" block bind:tap="goEdit">编辑团购</t-button>
      <!-- 收场出口：人数不够/没谈成时给个体面台阶，别让失败的团挂成僵尸 -->
      <t-button
        wx:if="{{nextState && matter.abort_state}}"
        class="leader-btn abort-btn"
        theme="light"
        size="medium"
        block
        bind:tap="abortMatter"
        >按「{{matter.abort_state.label}}」收场</t-button
      >
    </view>
  </view>
</view>

<view class="card" wx:if="{{matter.updates.length}}">
  <view class="kicker">进度更新</view>
  <view class="tline" wx:for="{{matter.updates}}" wx:key="index">
    <view class="tline-dot {{index === 0 ? 'tline-dot-latest' : ''}}"></view>
    <view class="tline-main">
      <view class="tline-date">{{item.happened_on}}{{item.author ? ' · ' + item.author + '（官方回应）' : ''}}</view>
      <view class="tline-content">{{item.content}}</view>
      <view class="tline-shots" wx:if="{{item.images.length}}">
        <image
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          class="tline-shot"
          src="{{img}}"
          mode="aspectFill"
          data-urls="{{item.images}}"
          data-current="{{img}}"
          bind:tap="previewImage"
        />
      </view>
    </view>
  </view>
</view>

<view class="card" wx:if="{{matter.roster.length}}">
  <view class="kicker">报名接龙</view>
  <view class="roster-row" wx:for="{{matter.roster}}" wx:key="index">
    <text class="roster-idx">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
    <text>{{item}}</text>
  </view>
</view>

<view class="card" wx:if="{{matter.review_open && (reviews.length || joined)}}">
  <view class="kicker">参团邻居的评价{{reviews.length ? '（' + reviews.length + '）' : ''}}</view>

  <block wx:if="{{joined}}">
    <view class="review-form">
      <view class="review-form-title">{{myReview ? '我的评价（可修改）' : '这单结束了，给它打个分吧'}}</view>
      <t-rate value="{{reviewRating}}" size="44rpx" bind:change="onRateChange" />
      <textarea
        class="fin review-input"
        auto-height
        value="{{reviewContent}}"
        bind:input="onReviewInput"
        maxlength="500"
      />
      <t-button
        theme="light"
        size="medium"
        block
        style="width: 100%"
        loading="{{submittingReview}}"
        bind:tap="submitReview"
      >
        {{myReview ? '更新评价' : '发布评价'}}
      </t-button>
    </view>
  </block>

  <view class="review-row" wx:for="{{reviews}}" wx:key="index">
    <view class="review-head">
      <text class="review-name">{{item.reviewer_name}}</text>
      <text class="review-stars">{{item.stars}}</text>
    </view>
    <view class="review-content" wx:if="{{item.content}}">{{item.content}}</view>
    <view class="review-date">{{item.reviewed_on}}</view>
  </view>
</view>

<view class="cta-dock" wx:if="{{matter.join_open && !isParty}}">
  <!-- 一眼看清「占没占上名额」：确认参团=占了，登记意向≠占 -->
  <view class="cta-standing" wx:if="{{joined && !needConfirm}}">
    <text wx:if="{{myJoinStage === 'confirmed'}}">✓ 你已确认参团，名额已占</text>
    <text wx:else class="cta-standing-intent">你登记了意向，还没占名额 · 条件谈定后需「确认参团」</text>
  </view>
  <!-- 登记过意向、条件已谈定：确认参团是此刻唯一的主动作 -->
  <block wx:if="{{needConfirm}}">
    <view class="cta-share">
      <text class="cta-share-text">条件谈定了。你登记过意向，确认参团后才计入成团人数</text>
    </view>
    <t-button theme="primary" block size="large" style="width: 100%" loading="{{submitting}}" bind:tap="confirmJoin"
      >确认参团</t-button
    >
    <t-button
      theme="default"
      variant="outline"
      block
      size="medium"
      class="cta-secondary"
      style="width: 100%"
      bind:tap="toggleJoin"
      >这次不参加了</t-button
    >
  </block>
  <block wx:else>
    <view class="cta-share" wx:if="{{!joined}}">
      <text class="cta-share-text"
        >{{matter.needs_survey && intentPhase ? '同意团长/商家联系我沟通需求、出方案（手机号仅双方可见）' :
        '成团后与团长互通手机号（仅双方可见）'}}</text
      >
      <switch checked="{{shareContact}}" bind:change="onShareContactChange" color="#06ae56" />
    </view>
    <!-- 已在名单里时主动作变成「取消 xx」：中性描边样式说明这是次要动作，点击有确认弹窗兜底。
         宽度用 style 直传：block 缩写在部分基础库不生效，外部 class 受 virtualHost 限制（与 insights 页同因） -->
    <t-button
      theme="{{joined ? 'default' : 'primary'}}"
      variant="{{joined ? 'outline' : 'base'}}"
      block
      size="large"
      style="width: 100%"
      loading="{{submitting}}"
      bind:tap="toggleJoin"
      >{{joined ? (myJoinStage === 'intent' ? '取消登记' : '取消参团') : (intentPhase ? (matter.needs_survey ?
      '我感兴趣，等我的方案' : '我感兴趣，登记意向') : '确认参团')}}</t-button
    >
  </block>
</view>

<!-- 相关方身份：不进接龙名单，但说清楚为什么、怎么参与 -->
<view class="cta-dock" wx:if="{{matter.join_open && isParty}}">
  <view class="party-note">你正以「{{partyLabel}}」身份浏览，接龙名单仅向业主开放</view>
  <t-button theme="light" block size="large" style="width: 100%" bind:tap="goSwitchIdentity">切回业主身份并报名</t-button>
</view>

<!-- 就地解释弹层：点中文案里的术语时弹出对应的「买前必懂」决策卡 -->
<t-popup visible="{{!!activeTerm}}" placement="bottom" bind:visible-change="onTermPopupChange">
  <view class="term-pop" wx:if="{{activeTerm}}">
    <view class="term-pop-title">{{activeTerm.term}}</view>
    <view class="gl-explain">{{activeTerm.explain}}</view>
    <view class="term-pop-source">来自本团购的「买前必懂」，由发起人整理</view>
    <t-button theme="light" size="medium" block style="width: 100%" class="term-pop-ask" bind:tap="askTermAi"
      >问 AI：我家该怎么选</t-button
    >
  </view>
</t-popup>
