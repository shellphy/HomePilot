.cta-standing {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-deep);
  margin-bottom: 12rpx;
}
.cta-standing-intent {
  font-weight: 400;
  color: var(--text-muted);
}
.head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.head-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.head-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.head-meter {
  margin-top: 20rpx;
}
/* 福利是正向激励，用品牌绿系；橙色留给「谈判中」这类需要注意的语义 */
.head-perk {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--brand-deep);
  background: var(--brand-bg);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
}
/* 待确认的意向数：提醒而非警告，用橙色注意语义 */
.head-intent {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--warn);
  background: var(--warn-bg);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
}
/* 方案型团购的玩法说明：信息语义，蓝色 */
.head-survey {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--info);
  background: var(--info-bg);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  line-height: 1.6;
}

.pitch {
  font-size: 27rpx;
  line-height: 1.75;
}
.pitch-sign {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.pending-tip {
  font-size: 24rpx;
  color: var(--warn);
  background: var(--warn-bg);
  line-height: 1.7;
}
.pending-tip-reject {
  color: var(--danger);
  background: var(--danger-bg);
}

.term-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
}
.term-row:last-child {
  border-bottom: none;
}
.term-label {
  color: var(--text-secondary);
}
.term-value {
  font-weight: 600;
  text-align: left;
  max-width: 65%;
}

.gl {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.gl:last-child {
  border-bottom: none;
}
.gl-term {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.gl-explain {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.65;
}
/* 文案里命中「买前必懂」术语的段：可点，虚线下划线示意可展开 */
.term-hit {
  color: var(--info);
  text-decoration: underline dashed;
  text-underline-offset: 6rpx;
}
/* 就地解释弹层 */
.term-pop {
  padding: 40rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
}
.term-pop-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.term-pop-source {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}
.term-pop-ask {
  margin-top: 24rpx;
}
/* 配套摸底问卷入口卡 */
.census-attach-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.census-attach-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.tline {
  display: flex;
  gap: 20rpx;
  padding-bottom: 20rpx;
}
.tline:last-child {
  padding-bottom: 0;
}
.tline-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--line-dark);
  margin-top: 10rpx;
}
.tline-dot-latest {
  background: var(--brand);
}
.tline-date {
  font-size: 22rpx;
  color: var(--text-muted);
}
.tline-content {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 2rpx;
}
.tline-shots {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}
.tline-shot {
  width: 148rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: var(--line);
}

.leader-ops {
  border: 2rpx solid var(--brand);
}
/* 主操作占整行、次操作两列对齐：竖排容器夹一层两列子容器 */
.leader-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.leader-btns-sub {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
/* 等宽两列；flex-grow 让落单的按钮撑满整行，避免半格空缺 */
.leader-btn {
  flex: 1 1 calc(50% - 8rpx);
}

.roster-row {
  display: flex;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 25rpx;
}
.roster-row:last-child {
  border-bottom: none;
}
.roster-idx {
  color: var(--text-muted);
  width: 44rpx;
  flex-shrink: 0;
}

.deal-card {
  border: 2rpx solid var(--brand);
}
.deal-note {
  font-size: 24rpx;
  color: var(--brand-deep);
  background: var(--brand-bg);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-top: 18rpx;
  line-height: 1.7;
}

.review-form {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--line);
  margin-bottom: 8rpx;
}
.review-form-title {
  font-size: 25rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}
.review-input {
  height: auto;
  min-height: 100rpx;
  line-height: 1.6;
  padding: 18rpx 24rpx;
  margin: 18rpx 0;
}
.review-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.review-row:last-child {
  border-bottom: none;
}
.review-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.review-name {
  font-size: 25rpx;
  font-weight: 600;
}
.review-stars {
  font-size: 24rpx;
  color: #f5a623;
  letter-spacing: 2rpx;
}
.review-content {
  font-size: 25rpx;
  line-height: 1.7;
  margin-top: 8rpx;
}
.review-date {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.cta-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  /* 吸底操作条必须盖住滚动内容：qa-panel「我要提问」在 DOM 里排在本组件之后，
     不给 z-index 会被后面的内容画在上面（与 app.wxss 的 .footer-bar 同为 10） */
  z-index: 10;
  /* 顶部留足内边距，配合更晚的渐变收口，让互通提示行落在纯色背景上、与上方内容拉开距离 */
  padding: 44rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #f6f6f3 88%, rgba(246, 246, 243, 0));
}
.cta-share {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.cta-share-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
.cta-share switch {
  transform: scale(0.8);
  transform-origin: right center;
}

/* 成团后没共享联系方式的说明（互通是双向的） */
.share-note {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 16rpx;
}

/* 相关方身份的报名区说明 */
.party-note {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

/* 确认参团下方的次要出口（退出名单） */
.cta-secondary {
  margin-top: 16rpx;
}

/* 收场是负向但正当的出口：红字点明分量，浅底不抢戏 */
.abort-btn {
  --td-button-light-color: var(--danger);
}
