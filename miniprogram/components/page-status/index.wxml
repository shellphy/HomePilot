<view wx:if="{{loaded}}"><slot /></view>

<!-- 错误态：加深的标题行，一眼看出是出错了 -->
<view wx:elif="{{error}}" class="hint load-error" bind:tap="onRetry">
  <view class="load-error-title">没能加载出来</view>
  {{error}}
  <view class="hint-retry">点击重试</view>
</view>

<block wx:else>
  <view class="card"><t-skeleton theme="paragraph" loading animation="gradient" /></view>
  <view class="card"><t-skeleton theme="paragraph" loading animation="gradient" /></view>
</block>
