.chat-panel {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--bg-page);
}
.chat-head {
  padding: 28rpx 24rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--line);
}
.chat-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}
.chat-tip {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}
.chat-clear {
  color: var(--info);
}
.chat-body {
  flex: 1;
  min-height: 0;
  /* 右侧多留一点空间给原生滚动条，避免压到访客消息气泡 */
  padding: 24rpx 32rpx 24rpx 24rpx;
  box-sizing: border-box;
}
.bubble-row {
  display: flex;
  /* AI 气泡右侧保留呼吸空间，长回复不会横跨整个消息区 */
  padding-right: 48rpx;
  margin-bottom: 20rpx;
}
.bubble-row-me {
  justify-content: flex-end;
  /* 访客气泡收窄并避开右侧滚动条 */
  padding-right: 8rpx;
  padding-left: 56rpx;
}
.bubble {
  max-width: 78%;
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}
.bubble-ai {
  background: #fff;
  color: var(--text-primary);
  border-top-left-radius: 6rpx;
}
.bubble-me {
  background: var(--brand);
  color: #fff;
  border-top-right-radius: 6rpx;
}
.bubble-typing {
  color: var(--text-muted);
}
/* markdown 气泡：rich-text 继承气泡字号行高，块级元素间距由内联 style 控制 */
.bubble-md {
  display: inline;
  font-size: 28rpx;
  line-height: 1.7;
}
.chat-quota {
  text-align: center;
  font-size: 22rpx;
  color: var(--warn);
  padding: 8rpx 0;
}
.chat-anchor {
  height: 2rpx;
}
/* 「猜你想问」：空对话时贴着输入框上方，点一条即发送。和输入区同白底连成一块 */
.chat-presets {
  background: #fff;
  padding: 20rpx 24rpx 6rpx;
  border-top: 1rpx solid var(--line);
}
.chat-presets-title {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}
.chat-presets-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.chat-preset {
  background: var(--brand-bg);
  color: var(--brand-deep);
  border-radius: 16rpx;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
}
.chat-preset-hover {
  opacity: 0.7;
}

/* 输入区：多行输入 + 圆形感发送键，未输入时置灰 */
.chat-input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--line);
}
.chat-input {
  flex: 1;
  background: var(--bg-page);
  border-radius: 24rpx;
  padding: 20rpx 26rpx;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 44rpx;
  max-height: 240rpx;
  box-sizing: content-box;
}
.chat-send {
  flex-shrink: 0;
  width: 108rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 38rpx;
  background: var(--brand);
  color: #fff;
  font-size: 27rpx;
  font-weight: 600;
}
.chat-send-off {
  background: var(--line-dark);
}
/* 生成中：发送键变停止键，居中一个方块停止图标 */
.chat-send-stop {
  display: flex;
  align-items: center;
  justify-content: center;
}
.stop-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: #fff;
}
