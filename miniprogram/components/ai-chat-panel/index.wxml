<view class="chat-panel">
  <view class="chat-head">
    <view class="chat-title">{{matterTitle || 'AI 帮你看懂'}}</view>
    <view class="chat-tip">
      <text>由 DeepSeek 大模型回答，仅供参考</text>
      <text wx:if="{{messages.length}}" class="chat-clear" bind:tap="resetChat">清空对话</text>
    </view>
  </view>

  <scroll-view class="chat-body" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <view wx:for="{{messages}}" wx:key="index" class="bubble-row {{item.role === 'user' ? 'bubble-row-me' : ''}}">
      <view class="bubble {{item.role === 'user' ? 'bubble-me' : 'bubble-ai'}}">
        <!-- 流式 AI 气泡：还没吐字时显示等待文案，正在打字时文末带光标 -->
        <block wx:if="{{index === streamingIndex && !item.text}}">
          <text class="bubble-typing">正在思考中</text>
        </block>
        <!-- AI 回答按 markdown 渲染（rich-text）；用户提问保持纯文本 -->
        <block wx:elif="{{item.role === 'ai'}}">
          <rich-text class="bubble-md" nodes="{{item.nodes}}"></rich-text>
        </block>
        <block wx:else>
          <text>{{item.text}}</text>
        </block>
      </view>
    </view>

    <view wx:if="{{remaining !== null && remaining <= 5}}" class="chat-quota">今天还能问 {{remaining}} 次</view>
    <view id="chat-bottom" class="chat-anchor"></view>
  </scroll-view>

  <!-- 空对话时把预设问题以「猜你想问」摆在输入框上方，业主挑一条即发送，不用自己憋问题 -->
  <view wx:if="{{!messages.length && !busy && presets.length}}" class="chat-presets">
    <view class="chat-presets-title">猜你想问</view>
    <view class="chat-presets-list">
      <view
        wx:for="{{presets}}"
        wx:key="*this"
        class="chat-preset"
        hover-class="chat-preset-hover"
        data-q="{{item}}"
        bind:tap="pickPreset"
        >{{item}}</view
      >
    </view>
  </view>

  <view class="chat-input-bar">
    <textarea
      class="chat-input"
      auto-height
      maxlength="300"
      value="{{input}}"
      confirm-type="send"
      adjust-position
      bind:input="onInput"
      bind:confirm="send"
    />
    <view class="chat-send {{busy ? 'chat-send-stop' : (input ? '' : 'chat-send-off')}}" bind:tap="onSendTap">
      <view wx:if="{{busy}}" class="stop-icon" />
      <text wx:else>发送</text>
    </view>
  </view>
</view>
