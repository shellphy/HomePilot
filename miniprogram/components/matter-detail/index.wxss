.head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.head-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.head-count {
  font-size: 25rpx;
  color: var(--text-secondary);
}
.head-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.mcard-tag {
  font-size: 21rpx;
  font-weight: 600;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  color: var(--text-secondary);
  background: var(--bg-page);
}
.mcard-tag-rights {
  color: var(--danger);
  background: #fbe9e0;
}
.mcard-tag-activity {
  color: var(--brand-deep);
  background: var(--brand-bg);
}
.mcard-tag-aid {
  color: var(--info);
  background: var(--info-bg);
}

.pitch {
  font-size: 27rpx;
  line-height: 1.75;
}
.pitch-sign {
  font-size: 23rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.pending-tip {
  font-size: 24rpx;
  color: var(--warn);
  background: var(--warn-bg);
  line-height: 1.7;
}
.pending-tip-reject {
  color: var(--danger);
  background: var(--danger-bg);
}

.leader-ops {
  border: 2rpx dashed var(--brand);
}
.leader-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 收场是负向但正当的出口：红字点明分量，浅底不抢戏 */
.abort-btn {
  --td-button-light-color: var(--danger);
}

.tline {
  display: flex;
  gap: 20rpx;
  padding-bottom: 20rpx;
}
.tline:last-child {
  padding-bottom: 0;
}
.tline-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--line-dark);
  margin-top: 10rpx;
}
.tline-dot-latest {
  background: var(--brand);
}
.tline-date {
  font-size: 22rpx;
  color: var(--text-muted);
}
.tline-content {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 2rpx;
}
.tline-shots {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}
.tline-shot {
  width: 148rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: var(--line);
}

.roster-row {
  display: flex;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 25rpx;
}
.roster-row:last-child {
  border-bottom: none;
}
.roster-idx {
  color: var(--text-muted);
  width: 44rpx;
  flex-shrink: 0;
}

.review-form {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--line);
  margin-bottom: 8rpx;
}
.review-form-title {
  font-size: 25rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}
.review-input {
  height: auto;
  min-height: 100rpx;
  line-height: 1.6;
  padding: 18rpx 24rpx;
  margin: 18rpx 0;
}
.review-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.review-row:last-child {
  border-bottom: none;
}
.review-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.review-name {
  font-size: 25rpx;
  font-weight: 600;
}
.review-stars {
  font-size: 24rpx;
  color: #f5a623;
  letter-spacing: 2rpx;
}
.review-content {
  font-size: 25rpx;
  line-height: 1.7;
  margin-top: 8rpx;
}
.review-date {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.cta-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  /* 顶部留足内边距，配合更晚的渐变收口，让互通提示行落在纯色背景上、与上方内容拉开距离 */
  padding: 44rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #f6f6f3 88%, rgba(246, 246, 243, 0));
}
.cta-share {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.cta-share-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
.cta-share switch {
  transform: scale(0.8);
  transform-origin: right center;
}

/* 联系互通卡片（与团购详情同一套视觉） */
.deal-card {
  border: 2rpx solid var(--brand);
}
.term-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
}
.term-row:last-child {
  border-bottom: none;
}
.term-label {
  color: var(--text-secondary);
}
.term-value {
  font-weight: 600;
  text-align: right;
  max-width: 65%;
}

/* 互通阶段没共享联系方式的说明（互通是双向的） */
.share-note {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 16rpx;
}

/* 相关方身份的参与区说明 */
.party-note {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}
