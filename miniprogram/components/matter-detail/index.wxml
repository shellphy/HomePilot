<view class="card">
  <view class="head-row">
    <view class="head-left">
      <view class="mcard-tag mcard-tag-{{matter.type}}">{{matter.type_label}}</view>
      <view class="pill {{pillClass}}">{{matter.state_label}}</view>
    </view>
    <view class="head-count">
      <text class="head-num">{{matter.join_count}}</text>
      <text>{{matter.target_count ? ' / ' + matter.target_count : ''}} {{meta.foot}}</text>
    </view>
  </view>
</view>

<view class="card" wx:if="{{matter.pitch}}">
  <view class="kicker">发起人说</view>
  <view class="pitch">“{{matter.pitch}}”</view>
  <view class="pitch-sign" wx:if="{{matter.initiator_name}}">—— {{matter.initiator_name}} · {{matter.initiator_party ? '已认证' + matter.initiator_party.label + ' · 牵头人' : '牵头人'}}</view>
</view>

<!-- 驳回是「需要你处理」的负面结果，用红系；排队等待保持橙色中性 -->
<view class="card pending-tip {{matter.reject_reason ? 'pending-tip-reject' : ''}}" wx:if="{{!matter.is_approved}}">
  <block wx:if="{{matter.reject_reason}}">已被驳回：{{matter.reject_reason}}（修改后保存即重新提交审核）</block>
  <block wx:else>待管理员审核，通过后才会出现在小区页里（只有你自己能看到这个页面）</block>
</view>

<!-- 联系互通阶段（活动报名中/互助进行中）：参与者见发起人 -->
<view class="card deal-card" wx:if="{{initiatorContact}}">
  <view class="kicker">联系发起人 · 拉群与对接</view>
  <view class="term-row">
    <text class="term-label">{{initiatorContact.name}}</text>
    <text class="term-value" data-phone="{{initiatorContact.phone}}" bind:tap="onPhoneTap">{{initiatorContact.phone}} 拨打/复制</text>
  </view>
</view>

<!-- 互通阶段没共享联系方式的参与者：解释互通是双向对等的，给补开入口 -->
<view class="card deal-card" wx:if="{{matter.contacts_open && joined && !isInitiator && !myShareContact}}">
  <view class="kicker">联系发起人 · 拉群与对接</view>
  <view class="share-note">你加入时没有开启联系方式共享，所以你和发起人互相看不到对方电话（互通是双向的）。</view>
  <t-button theme="light" size="medium" block style="width: 100%" bind:tap="enableShare">开启共享，与发起人互通</t-button>
</view>

<!-- 联系互通阶段：发起人见同意共享的参与者 -->
<view class="card deal-card" wx:if="{{isInitiator && contacts.length}}">
  <view class="kicker">参与联系名单（{{contacts.length}}）· 仅你可见，用于拉群对接</view>
  <view class="term-row" wx:for="{{contacts}}" wx:key="phone">
    <text class="term-label">{{item.name}}</text>
    <text class="term-value" data-phone="{{item.phone}}" bind:tap="onPhoneTap">{{item.phone}} 拨打/复制</text>
  </view>
</view>

<view class="card leader-ops" wx:if="{{isInitiator}}">
  <view class="kicker">牵头人操作（这件事由你负责）</view>
  <!-- 唯一的 primary 放最前：日常最常做的是发进展 -->
  <view class="leader-btns">
    <t-button theme="primary" size="medium" bind:tap="goProgress">发布进展</t-button>
    <t-button wx:if="{{nextState}}" theme="light" size="medium" bind:tap="flipState">推进到「{{nextState.label}}」</t-button>
    <t-button theme="light" size="medium" bind:tap="goEdit">编辑</t-button>
    <!-- 收场出口：办不成/不再推进时给个体面台阶，别让事项挂成僵尸 -->
    <t-button wx:if="{{nextState && matter.abort_state}}" theme="light" size="medium" class="abort-btn" bind:tap="abortMatter">按「{{matter.abort_state.label}}」收场</t-button>
  </view>
</view>

<!-- 被认证的治理类相关方（物业/开发商/业委会）：官方回应入口，进展时间线里带署名 -->
<view class="card leader-ops" wx:if="{{canRespond && !isInitiator}}">
  <view class="kicker">你以认证相关方身份出现，可对这件事正式回应</view>
  <view class="leader-btns">
    <t-button theme="light" size="medium" bind:tap="goProgress">发布官方回应</t-button>
  </view>
</view>

<view class="card" wx:if="{{matter.updates.length}}">
  <view class="kicker">进展</view>
  <view class="tline" wx:for="{{matter.updates}}" wx:key="index">
    <view class="tline-dot {{index === 0 ? 'tline-dot-latest' : ''}}"></view>
    <view class="tline-main">
      <view class="tline-date">{{item.happened_on}}{{item.author ? ' · ' + item.author + '（官方回应）' : ''}}</view>
      <view class="tline-content">{{item.content}}</view>
      <view class="tline-shots" wx:if="{{item.images.length}}">
        <image
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          class="tline-shot"
          src="{{img}}"
          mode="aspectFill"
          data-urls="{{item.images}}"
          data-current="{{img}}"
          bind:tap="previewImage"
        />
      </view>
    </view>
  </view>
</view>

<view class="card" wx:if="{{matter.roster.length}}">
  <view class="kicker">{{meta.roster}} · {{matter.roster_hidden ? '不对外公示，仅你可见' : '楼栋 + 昵称对外可见'}}</view>
  <view class="roster-row" wx:for="{{matter.roster}}" wx:key="index">
    <text class="roster-idx">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
    <text>{{item}}</text>
  </view>
</view>

<!-- 名单不公示的类型（如维权联名）：对外只给计数，降低参与顾虑 -->
<view class="card" wx:if="{{!matter.roster.length && matter.roster_hidden && matter.join_count}}">
  <view class="kicker">{{meta.roster}}</view>
  <view class="hint">已有 {{matter.join_count}} 人联名。名单不对外公示（仅牵头人可见），放心参与。</view>
</view>

<view class="card" wx:if="{{matter.review_open && (reviews.length || joined)}}">
  <view class="kicker">参与邻居的评价{{reviews.length ? '（' + reviews.length + '）' : ''}}</view>

  <block wx:if="{{joined}}">
    <view class="review-form">
      <view class="review-form-title">{{myReview ? '我的评价（可修改）' : '这件事结束了，给它打个分吧'}}</view>
      <t-rate value="{{reviewRating}}" size="44rpx" bind:change="onRateChange" />
      <textarea
        class="fin review-input"
        auto-height
        placeholder="一句话真实感受，给后来的邻居留个参考"
        value="{{reviewContent}}"
        bind:input="onReviewInput"
        maxlength="500"
      />
      <t-button theme="light" size="medium" block style="width: 100%" loading="{{submittingReview}}" bind:tap="submitReview">
        {{myReview ? '更新评价' : '发布评价'}}
      </t-button>
    </view>
  </block>

  <view class="review-row" wx:for="{{reviews}}" wx:key="index">
    <view class="review-head">
      <text class="review-name">{{item.reviewer_name}}</text>
      <text class="review-stars">{{item.stars}}</text>
    </view>
    <view class="review-content" wx:if="{{item.content}}">{{item.content}}</view>
    <view class="review-date">{{item.reviewed_on}}</view>
  </view>
</view>

<view class="cta-dock" wx:if="{{matter.join_open && !isParty}}">
  <!-- 互通联系方式的类型（活动/互助）：加入前用开关选共享意愿；维权不互通，开关不出现 -->
  <view class="cta-share" wx:if="{{!joined && matter.contacts_open}}">
    <text class="cta-share-text">{{meta.shareText || '与发起人互通手机号（仅双方可见）'}}</text>
    <switch checked="{{shareContact}}" bind:change="onShareContactChange" color="#06ae56" />
  </view>
  <!-- 已加入后主动作变成「取消 xx」：中性描边样式说明这是次要动作，点击有确认弹窗兜底。
       宽度用 style 直传：block 缩写在部分基础库不生效，外部 class 受 virtualHost 限制（与 insights 页同因） -->
  <t-button
    theme="{{joined ? 'default' : 'primary'}}"
    variant="{{joined ? 'outline' : 'base'}}"
    block
    size="large"
    style="width: 100%"
    loading="{{submitting}}"
    bind:tap="toggleJoin"
  >{{joined ? meta.joinedCta : meta.joinCta}}</t-button>
</view>

<!-- 相关方身份：不进名单，但说清楚为什么、怎么参与 -->
<view class="cta-dock" wx:if="{{matter.join_open && isParty}}">
  <view class="party-note">你正以「{{partyLabel}}」身份浏览，{{meta.roster}}仅向业主开放</view>
  <t-button theme="light" block size="large" style="width: 100%" bind:tap="goSwitchIdentity">切回业主身份参与</t-button>
</view>
