.ccard-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.ccard-tag {
  font-size: 21rpx;
  font-weight: 600;
  color: var(--brand-deep);
  background: var(--brand-bg);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}
.ccard-title {
  flex: 1;
  font-size: 29rpx;
  font-weight: 600;
}
.ccard-pitch {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.ccard-meter {
  margin-top: 16rpx;
}
.ccard-foot {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 14rpx;
}
.ccard-num {
  font-weight: 700;
  color: var(--text-primary);
}
.ccard-cta {
  color: var(--brand-deep);
  font-weight: 600;
}
