<view class="card ccard" hover-class="card-hover" bind:tap="goInsights">
  <view class="ccard-row">
    <view class="ccard-tag">征集</view>
    <view class="ccard-title">{{matter.title}}</view>
    <view class="pill {{pillClass}}">{{matter.state_label}}</view>
  </view>
  <view wx:if="{{matter.pitch}}" class="ccard-pitch">{{matter.pitch}}</view>
  <!-- 署名发起的调研：亮明发起方是开放发起权的前提，业主看得到是谁想了解什么 -->
  <view wx:if="{{matter.initiator_party}}" class="ccard-sign">{{matter.initiator_party.label}} · {{matter.initiator_party.name}} 发起，结果对全小区公开</view>
  <view class="ccard-foot">
    <text><text class="ccard-num">{{matter.register_count}}</text> 人已登记</text>
    <text class="ccard-cta">{{matter.registered_by_me ? '看数据 / 改登记 ›' : '2 分钟完成登记 ›'}}</text>
  </view>
</view>
