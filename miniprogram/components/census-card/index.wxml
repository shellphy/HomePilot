<view class="card ccard" bind:tap="goInsights">
  <view class="ccard-row">
    <view class="ccard-tag">征集</view>
    <view class="ccard-title">{{matter.title}}</view>
    <view class="pill {{matter.state === 'open' ? 'pill-open' : 'pill-done'}}">{{matter.state_label}}</view>
  </view>
  <view wx:if="{{matter.pitch}}" class="ccard-pitch">{{matter.pitch}}</view>
  <view class="ccard-foot">
    <text><text class="ccard-num">{{matter.register_count}}</text> 户已登记</text>
    <text class="ccard-cta">{{matter.registered_by_me ? '看数据 / 改登记 ›' : '2 分钟完成登记 ›'}}</text>
  </view>
</view>
