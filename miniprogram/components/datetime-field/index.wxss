:host {
  display: block;
}

/* 与行式表单（.frow）同款：标签左、值右对齐、细分割线 */
.dt-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 116rpx;
  border-bottom: 1rpx solid var(--line);
  box-sizing: border-box;
}

.dt-label {
  flex-shrink: 0;
  color: var(--text-primary);
  font-size: 28rpx;
}

.dt-required {
  margin-left: 8rpx;
  color: var(--danger);
  font-size: 20rpx;
}

/* 日期、时间并成一个值：两段可点文本靠右排，无边框盒子 */
.dt-value {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  gap: 32rpx;
}

.dt-pick {
  min-width: 0;
}

.dt-seg {
  font-size: 28rpx;
  color: var(--text-primary);
}

.dt-seg-hover {
  opacity: 0.5;
}

.dt-ph {
  color: var(--text-muted);
}
