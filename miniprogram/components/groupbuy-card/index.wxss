.gcard-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.gcard-cat {
  font-size: 21rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--bg-page);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}
.gcard-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
}
.gcard-done .gcard-title {
  color: var(--text-muted);
}
.gcard-perk {
  font-size: 25rpx;
  color: var(--warn);
  margin-top: 14rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.gcard-meter {
  margin-top: 16rpx;
}
.gcard-foot {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 14rpx;
}
.gcard-num {
  font-weight: 700;
  color: var(--text-primary);
}

.merchant-line {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--warn);
}
