<view class="card gcard {{matter.state === 'done' || matter.state === 'aborted' ? 'gcard-done' : ''}}" hover-class="card-hover" bind:tap="goDetail">
  <view class="gcard-row">
    <view class="gcard-cat">{{matter.category}}</view>
    <view class="gcard-title">{{matter.title}}</view>
    <view class="pill {{pillClass}}">{{matter.state_label}}</view>
  </view>
  <view wx:if="{{matter.initiator_party}}" class="merchant-line">{{matter.initiator_party.name}} · 已认证{{matter.initiator_party.label}}发起</view>
  <view wx:if="{{matter.perk}}" class="gcard-perk">{{matter.perk}}</view>
  <view wx:if="{{matter.starts_on}}" class="muted">{{matter.starts_on}}{{matter.location ? ' · ' + matter.location : ''}}</view>
  <view wx:if="{{matter.registration_deadline_on}}" class="muted">报名截止 {{matter.registration_deadline_on}}</view>
  <view wx:if="{{matter.state === 'open' && matter.target_count}}" class="meter gcard-meter">
    <view class="meter-fill" style="width: {{percent}}%"></view>
  </view>
  <view class="gcard-foot">
    <text><text class="gcard-num">{{footCount}}</text>{{matter.target_count ? ' / ' + matter.target_count : ''}} 人{{footNoun}}</text>
  </view>
</view>
